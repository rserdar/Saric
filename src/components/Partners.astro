---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

type Partner = CollectionEntry<'partners'>;
const partners = (await getCollection('partners')).sort((a: Partner, b: Partner) => Number(a.id) - Number(b.id));

const COLS = 4;
const total = partners.length;
const lastDesktopRow = Math.floor((total - 1) / COLS);

function getBorderClasses(i: number): string {
  const row = Math.floor(i / COLS);
  const col = i % COLS;
  const isLastDesktopRow = row === lastDesktopRow;
  const isLastMobileRow = i >= total - 2;

  const classes: string[] = [];

  if (!isLastDesktopRow) {
    classes.push('border-b-2');
  } else if (!isLastMobileRow) {
    classes.push('border-b-2 md:border-b-0');
  }

  if (col === 0) {
    // no left border
  } else if (col === 2) {
    classes.push('md:border-l-2');
  } else {
    classes.push('border-l-2');
  }

  return classes.join(' ');
}
---

<section class="relative pb-8">
  <div class="container relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 border-2 border-[#eee] dark:border-[#555] rounded-[10px]">
      {partners.map((partner: Partner, i: number) => {
        const delay = i * 0.12;
        return (
          <div class={`${getBorderClasses(i)} border-[#eee] dark:border-[#555]`} data-animate="fade-in-up" data-animate-duration="0.8s" data-animate-delay={`${delay}s`}>
            <a href={partner.data.link} class="opacity-50 hover:opacity-100 cursor-pointer duration-300 h-[180px] flex items-center">
              <Image src={partner.data.logo.light} class="mx-auto max-w-[88%] dark:hidden" alt="" width={200} height={80} />
              <Image src={partner.data.logo.dark}  class="mx-auto max-w-[88%] hidden dark:block" alt="" width={200} height={80} />
            </a>
          </div>
        );
      })}
    </div>
  </div>
  <div class="-top-[170px] left-0 absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1.2s">
    <img src="/img/brushes/partners/1.png" alt="" class="brush-float-lr" />
  </div>
</section>
