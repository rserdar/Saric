---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);

const blogUi = {
  tr: {
    fallback: content.blog.fallback,
    loading: 'Yazılar yukleniyor...',
    blogLabel: 'Blog',
  },
  en: {
    fallback: content.blog.fallback,
    loading: 'Loading latest posts...',
    blogLabel: 'Blog',
  },
  bs: {
    fallback: content.blog.fallback,
    loading: 'Objave se ucitavaju...',
    blogLabel: 'Blog',
  },
} as const;

const ui = blogUi[lang];
const feedUrl = 'https://www.serdar.cc/feeds/posts/default?alt=json-in-script&max-results=3&callback=__serdarBlogFeed';
---

<section class="relative pt-[120px] pb-[100px] md:pt-[185px] md:pb-[160px]" id="blog">
  <div class="container-narrow relative z-10">
    <div class="grid grid-cols-1">
      <div class="mx-auto max-w-[680px] text-center">
        <p class="font-secondary text-[20px] font-medium text-custom md:text-2xl">{content.blog.tag}</p>
        <h3 class="mb-[23px] mt-1.5 text-[30px] leading-[1.25] sm:text-[38px] md:text-[48px]">{content.blog.title}</h3>
      </div>
    </div>

    <div
      class="grid grid-cols-1 gap-[25px] pt-[65px] md:grid-cols-2 lg:grid-cols-3"
      id="news-grid"
      data-blog-lang={lang}
      data-blog-fallback={ui.fallback}
      data-blog-loading={ui.loading}
      data-blog-label={ui.blogLabel}
    >
      {Array.from({ length: 3 }).map((_, i) => (
        <article class="overflow-hidden rounded-xl border border-white/6 bg-white/3 p-3 animate-pulse" data-news-skeleton>
          <div class="aspect-[4/3] rounded-xl bg-white/8"></div>
          <div class="mt-5 space-y-3 p-1">
            <div class="h-4 w-20 rounded bg-white/10"></div>
            <div class="h-6 w-full rounded bg-white/10"></div>
            <div class="h-6 w-4/5 rounded bg-white/10"></div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <div class="absolute left-[115px] top-[250px] hidden lg:block" data-animate="fade-in-left" data-animate-duration="1.2s">
    <img src="/img/brushes/news/1.png" alt="" class="brush-float" />
  </div>
  <div class="absolute right-0 top-0 hidden lg:block" data-animate="fade-in-right" data-animate-duration="1.2s" data-animate-delay="0.2s">
    <img src="/img/brushes/news/2.png" alt="" class="brush-float-lr-reverse" />
  </div>
</section>

<script define:vars={{ feedUrl }}>
  (() => {
    const grid = document.getElementById('news-grid');
    if (!(grid instanceof HTMLElement)) return;

    const fallbackText = grid.dataset.blogFallback || 'Posts could not be loaded.';
    const blogLabel = grid.dataset.blogLabel || 'Blog';
    const lang = grid.dataset.blogLang || 'tr';

    const monthFormatter = new Intl.DateTimeFormat(
      lang === 'tr' ? 'tr-TR' : lang === 'bs' ? 'bs-BA' : 'en-US',
      { month: 'short' }
    );

    const escapeHtml = (value) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const getBestImage = (entry) => {
      if (entry.media$thumbnail?.url) {
        return entry.media$thumbnail.url.replace(/\/s[0-9]+[^/]*\//, '/s1600/');
      }
      return '/img/blog/1.jpg';
    };

    const renderFallback = () => {
      grid.innerHTML = `<p class="col-span-3 py-10 text-center opacity-50">${escapeHtml(fallbackText)}</p>`;
    };

    const renderEntries = (entries) => {
      if (!entries.length) {
        renderFallback();
        return;
      }

      grid.innerHTML = entries.map((entry, i) => {
        const title = entry.title?.$t || blogLabel;
        const link = entry.link?.find((item) => item.rel === 'alternate')?.href || '#';
        const published = entry.published?.$t ? new Date(entry.published.$t) : null;
        const day = published ? String(published.getDate()).padStart(2, '0') : '--';
        const month = published ? monthFormatter.format(published).replace('.', '') : '---';
        const category = entry.category?.[0]?.term || blogLabel;
        const img = getBestImage(entry);

        return `
          <article class="cursor-pointer" data-animate="fade-in-up" data-animate-duration="1s" data-animate-delay="${i * 0.2}s">
            <a href="${escapeHtml(link)}" target="_blank" rel="noopener noreferrer" class="block">
              <div class="group relative aspect-[4/3] overflow-hidden rounded-xl">
                <img src="${escapeHtml(img)}" class="h-full w-full scale-100 rounded-xl object-cover duration-300 group-hover:scale-110" alt="${escapeHtml(title)}" />
                <div class="absolute right-[18px] top-[18px] z-20 inline-block min-w-[80px] rounded-xl bg-[#1cbe59] px-5 py-3 text-center">
                  <h3 class="font-secondary text-2xl leading-[1.2] text-white">${escapeHtml(day)}</h3>
                  <span class="font-secondary text-sm uppercase text-white">${escapeHtml(month)}</span>
                </div>
              </div>
              <div class="mt-5">
                <p class="font-secondary font-medium text-custom">${escapeHtml(category)}</p>
                <h4 class="mt-1 line-clamp-2 font-secondary text-[21px] font-medium leading-[1.4] transition-colors duration-300 hover:text-custom">${escapeHtml(title)}</h4>
              </div>
            </a>
          </article>
        `;
      }).join('');

      document.dispatchEvent(new Event('astro:page-load'));
    };

    window.__serdarBlogFeed = (data) => {
      const entries = data?.feed?.entry || [];
      renderEntries(entries);
    };

    const script = document.createElement('script');
    script.src = feedUrl;
    script.async = true;
    script.onerror = renderFallback;
    document.body.appendChild(script);

    window.setTimeout(() => {
      if (grid.querySelector('[data-news-skeleton]')) {
        renderFallback();
      }
    }, 7000);
  })();
</script>
