---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);

let entries = [];
try {
  const response = await fetch('https://www.serdar.cc/feeds/posts/default?alt=json&max-results=3');
  const data = await response.json();
  entries = data.feed.entry || [];
} catch (error) {
  console.error('Blogger Feed Error:', error);
}

function getBestImage(entry: any) {
  let imgUrl = '/img/blog/1.jpg';
  if (entry.media$thumbnail) {
    imgUrl = entry.media$thumbnail.url.replace(/\/s[0-9]+[^/]*\//, '/s1600/');
  }
  return imgUrl;
}
---

<section class="md:pt-[185px] pt-[120px] pb-[100px] md:pb-[160px] relative dizme_tm_section" id="blog">
  <div class="container relative z-10">
    <div class="grid grid-cols-1">
      <div class="text-center max-w-[680px] mx-auto">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.blog.tag}</p>
        <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mb-[23px] mt-1.5">{content.blog.title}</h3>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 pt-[65px] gap-[25px]">
      {entries.length > 0 ? entries.map((entry: any, i: number) => {
        const title = entry.title.$t;
        const link = entry.link.find((l: any) => l.rel === 'alternate').href;
        const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        const [datePart] = (entry.published.$t as string).split('T');
        const [, monthIdx, dayStr] = datePart.split('-');
        const day = parseInt(dayStr, 10);
        const month = MONTHS[parseInt(monthIdx, 10) - 1];
        const category = entry.category ? entry.category[0].term : 'Blog';
        const img = getBestImage(entry);

        return (
          <article class="cursor-pointer" data-animate="fade-in-up" data-animate-duration="1s" data-animate-delay={`${i * 0.2}s`}>
            <a href={link} target="_blank" rel="noopener noreferrer" class="block">
              <div class="overflow-hidden group rounded-xl relative aspect-[4/3]">
                <img src={img} class="scale-100 rounded-xl object-cover w-full h-full duration-300 group-hover:scale-110" alt={title} />
                <div class="bg-[#1cbe59] top-[18px] right-[18px] z-20 inline-block absolute rounded-xl text-center py-3 px-5 min-w-[80px]">
                  <h3 class="text-2xl text-white leading-[1.2] font-secondary">{day}</h3>
                  <span class="text-white text-sm uppercase font-secondary">{month}</span>
                </div>
              </div>
              <div class="mt-5">
                <p class="text-custom font-medium font-secondary">{category}</p>
                <h4 class="mt-1 leading-[1.4] text-[21px] font-medium font-secondary hover:text-custom transition-colors duration-300 line-clamp-2">{title}</h4>
              </div>
            </a>
          </article>
        );
      }) : (
        <p class="text-center col-span-3 py-10 opacity-50">{content.blog.fallback}</p>
      )}
    </div>
  </div>

  <div class="top-[250px] left-[115px] absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1.2s">
    <img src="/img/brushes/news/1.png" alt="" class="brush-float" />
  </div>
  <div class="top-0 right-0 absolute hidden lg:block" data-animate="fade-in-right" data-animate-duration="1.2s" data-animate-delay="0.2s">
    <img src="/img/brushes/news/2.png" alt="" class="brush-float-lr-reverse" />
  </div>
</section>
