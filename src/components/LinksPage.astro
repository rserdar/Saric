---
import LinksLayout from '../layouts/LinksLayout.astro';
import linksData from '../data/links.json';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

interface Props {
  lang: 'tr' | 'en' | 'bs';
}

const { lang } = Astro.props;
const data = linksData[lang];

// QR Kod ve kopyalama için dinamik sayfa adresi
const currentUrl = Astro.url.href.replace(Astro.url.origin, 'https://www.serdaryavuz.com');

// Yerelleştirilmiş footer alt link isimleri
const footerNav = {
  tr: { home: 'Ana Sayfa', contact: 'İletişim' },
  en: { home: 'Home', contact: 'Contact' },
  bs: { home: 'Početna', contact: 'Kontakt' }
};
const navLabels = footerNav[lang];
const ui = {
  tr: {
    toggleTheme: 'Karanlık modu değiştir',
    sharePage: 'Sayfayı paylaş',
    openPhoto: 'Profil fotoğrafını polaroid çerçevede aç',
    verifiedUser: 'Doğrulanmış kullanıcı',
    closeModal: 'Pencereyi kapat',
    closePhoto: 'Fotoğrafı kapat',
    qrAlt: 'QR kodu',
    shareTitle: 'Serdar Yavuz - Bağlantılar',
    copyError: 'Kopyalama hatası:',
    photoCaption: 'Eyl 2023, Belgrad'
  },
  en: {
    toggleTheme: 'Toggle dark mode',
    sharePage: 'Share page',
    openPhoto: 'Open profile photo in polaroid frame',
    verifiedUser: 'Verified user',
    closeModal: 'Close modal',
    closePhoto: 'Close photo',
    qrAlt: 'QR code',
    shareTitle: 'Serdar Yavuz - Links',
    copyError: 'Copy failed:',
    photoCaption: "Sep 2023, Belgrade"
  },
  bs: {
    toggleTheme: 'Promijeni tamni način rada',
    sharePage: 'Podijeli stranicu',
    openPhoto: 'Otvori profilnu fotografiju u polaroid okviru',
    verifiedUser: 'Verificirani korisnik',
    closeModal: 'Zatvori prozor',
    closePhoto: 'Zatvori fotografiju',
    qrAlt: 'QR kod',
    shareTitle: 'Serdar Yavuz - Linkovi',
    copyError: 'Greška pri kopiranju:',
    photoCaption: 'Sep 2023, Beograd'
  }
}[lang];

const linksCardClass = "w-full max-w-xl backdrop-blur-md bg-white/2 dark:bg-black/10 border border-white/8 dark:border-white/4 p-6 sm:p-10 rounded-[32px] shadow-[0_24px_60px_rgba(0,0,0,0.3)] flex flex-col items-center relative overflow-hidden z-10 [animation:var(--animate-links-fade-in)]";
const socialButtonClass = "w-10 h-10 rounded-full flex items-center justify-center border backdrop-blur-md text-white [background:var(--btn-hover-bg)] border-[var(--btn-hover-border)] transition-transform duration-200 active:scale-95 lg:[background:var(--btn-idle-bg)] lg:border-[var(--btn-idle-border)] lg:transition-all lg:duration-300 lg:[transition-timing-function:cubic-bezier(0.16,1,0.3,1)] lg:hover:[background:var(--btn-hover-bg)] lg:hover:border-[var(--btn-hover-border)] lg:hover:scale-[1.2] lg:hover:translate-y-[-3px] lg:hover:shadow-[0_0_22px_var(--hover-glow),0_12px_32px_-10px_var(--hover-glow),0_8px_20px_rgba(0,0,0,0.22)]";
const linkButtonClass = "group/item relative flex w-full items-center justify-center gap-2.5 rounded-xl border overflow-hidden px-6 py-3.5 text-center text-[15px] font-secondary font-bold text-white shadow-sm backdrop-blur-md [background:var(--btn-hover-bg)] border-[var(--btn-hover-border)] transition-transform duration-200 active:scale-[0.98] lg:[background:var(--btn-idle-bg)] lg:border-[var(--btn-idle-border)] lg:transition-all lg:duration-300 lg:[transition-timing-function:cubic-bezier(0.16,1,0.3,1)] lg:hover:[background:var(--btn-hover-bg)] lg:hover:border-[var(--btn-hover-border)] lg:hover:translate-y-[-5px] lg:hover:scale-[1.05] lg:hover:shadow-[0_0_28px_var(--hover-glow),0_18px_40px_-12px_var(--hover-glow),0_12px_28px_rgba(0,0,0,0.28)] lg:active:translate-y-0 lg:active:scale-[0.98] lg:hover:[&_.sheen-element]:[animation:var(--animate-sheen)]";
const polaroidCardBaseClass = "relative w-full max-w-[340px] rounded-sm border border-neutral-200/40 bg-[#fbfbf9] p-4 pb-14 shadow-[0_20px_50px_rgba(0,0,0,0.6),_inset_0_0_15px_rgba(0,0,0,0.05)] [backface-visibility:hidden] [outline:1px_solid_transparent] [transform-style:preserve-3d] sm:max-w-[400px] sm:p-5 sm:pb-20";
const polaroidCardOpenClass = "[transform:scale(1)_rotate(-3deg)] opacity-100 [transition:transform_0.8s_cubic-bezier(0.34,1.56,0.64,1),opacity_0.8s_ease,box-shadow_0.8s_ease] hover:[transform:scale(1)_rotate(0deg)] hover:shadow-[0_25px_60px_rgba(0,0,0,0.75),_inset_0_0_15px_rgba(0,0,0,0.05)]";
const polaroidCardClosingClass = "[transform:scale(0.01)_rotate(-723deg)] opacity-0 [transition:transform_0.8s_cubic-bezier(0.4,0,0.2,1),opacity_0.8s_ease-in-out]";
const polaroidImageWrapClass = "relative aspect-square w-full overflow-hidden border border-neutral-300 bg-neutral-900 shadow-inner [backface-visibility:hidden] [outline:1px_solid_transparent] [transform-style:preserve-3d]";
const polaroidImageClass = "h-full w-full object-cover sepia-[15%] contrast-[105%] [backface-visibility:hidden] [outline:1px_solid_transparent]";
const caveatTextClass = "inline-block rotate-[-1deg] text-3xl tracking-wide text-[#1a2536] [font-family:'Caveat',cursive] sm:text-4xl";

// hex → rgba dönüştürücü
const hexToRgba = (hex: string, alpha: number) => {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
};

// Platform renk haritası — hex + opsiyonel override'lar
const platforms: Record<string, { hex: string; glow?: string; hoverBorder?: string }> = {
  facebook:       { hex: '#1877f2' },
  'x-twitter':    { hex: '#0f1419', glow: 'rgba(255,255,255,0.15)', hoverBorder: 'rgba(255,255,255,0.12)' },
  twitter:        { hex: '#0f1419', glow: 'rgba(255,255,255,0.15)', hoverBorder: 'rgba(255,255,255,0.12)' },
  mastodon:       { hex: '#5c4ee5' },
  linkedin:       { hex: '#0a66c2' },
  pinterest:      { hex: '#e60023' },
  youtube:        { hex: '#ff0000' },
  steam:          { hex: '#171a21', glow: 'rgba(255,255,255,0.2)', hoverBorder: 'rgba(255,255,255,0.25)' },
  twitch:         { hex: '#9146ff' },
  discord:        { hex: '#5865f2' },
  github:         { hex: '#24292e', glow: 'rgba(255,255,255,0.2)', hoverBorder: 'rgba(255,255,255,0.3)' },
  reddit:         { hex: '#ff4500' },
  soundcloud:     { hex: '#ff5500' },
  tumblr:         { hex: '#35465c' },
  wordpress:      { hex: '#21759b' },
  blog:           { hex: '#f75023' },
  globe:          { hex: '#1cbe59' },
  'address-card': { hex: '#1d9bf0' },
  card:           { hex: '#1d9bf0' },
};

const fallbackStyle = {
  glow: 'rgba(255,255,255,0.2)',
  idleBg: 'rgba(255,255,255,0.05)',
  hoverBg: 'rgba(255,255,255,0.15)',
  idleBorder: 'rgba(255,255,255,0.1)',
  hoverBorder: 'rgba(255,255,255,0.15)',
};

const getLinkStyle = (icon: string) => {
  if (!icon) return fallbackStyle;
  const iconLower = icon.toLowerCase();

  // Instagram: gradient özel case
  if (iconLower.includes('instagram')) {
    return {
      glow: 'rgba(225,48,108,0.5)',
      idleBg: 'linear-gradient(to right,rgba(249,206,63,0.1),rgba(225,48,108,0.1),rgba(131,58,180,0.1))',
      hoverBg: 'linear-gradient(to right,#f9ce3f,#e1306c,#833ab4)',
      idleBorder: 'rgba(225,48,108,0.3)',
      hoverBorder: 'transparent',
    };
  }

  const key = Object.keys(platforms).find(k => iconLower.includes(k));
  if (!key) return fallbackStyle;

  const p = platforms[key];
  return {
    glow:        p.glow        ?? hexToRgba(p.hex, 0.45),
    idleBg:      hexToRgba(p.hex, 0.12),
    hoverBg:     p.hex,
    idleBorder:  p.glow ? 'rgba(255,255,255,0.1)' : hexToRgba(p.hex, 0.3),
    hoverBorder: p.hoverBorder ?? 'transparent',
  };
};
---

<LinksLayout title={data.title} description={data.description} lang={lang}>
  <!-- Üst Sağ Yüzen Kontroller -->
  <div class="fixed top-4 right-4 z-50 flex items-center gap-2 px-3 py-1.5 rounded-full bg-black/35 border border-white/10 backdrop-blur-md shadow-lg">
    <!-- Dil Seçici -->
    <div class="flex items-center gap-1.5 pr-2.5 border-r border-white/10">
      <a 
        href="/links" 
        data-lang-link="tr"
        class={`px-2 py-0.5 text-xs rounded-full font-bold transition-all duration-300 ${lang === 'tr' ? 'bg-[#f75023] text-white shadow shadow-orange-500/50' : 'text-white/60 hover:text-white hover:bg-white/5'}`}
      >
        TR
      </a>
      <a 
        href="/en/links" 
        data-lang-link="en"
        class={`px-2 py-0.5 text-xs rounded-full font-bold transition-all duration-300 ${lang === 'en' ? 'bg-[#f75023] text-white shadow shadow-orange-500/50' : 'text-white/60 hover:text-white hover:bg-white/5'}`}
      >
        EN
      </a>
      <a 
        href="/bs/links" 
        data-lang-link="bs"
        class={`px-2 py-0.5 text-xs rounded-full font-bold transition-all duration-300 ${lang === 'bs' ? 'bg-[#f75023] text-white shadow shadow-orange-500/50' : 'text-white/60 hover:text-white hover:bg-white/5'}`}
      >
        BS
      </a>
    </div>

    <!-- Karanlık Mod Butonu -->
    <button 
      id="theme-toggle" 
      class="w-7 h-7 flex items-center justify-center rounded-full text-white/70 hover:text-white hover:bg-white/5 transition-all duration-300 mr-1"
      aria-label={ui.toggleTheme}
    >
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 dark:hidden" fill="currentColor" viewBox="0 0 24 24">
        <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
      </svg>
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 4a1 1 0 011-1V1a1 1 0 00-2 0v2a1 1 0 011 1zm0 16a1 1 0 011 1v2a1 1 0 00-2 0v-2a1 1 0 011-1zM4 12a1 1 0 01-1 1H1a1 1 0 010-2h2a1 1 0 011 1zm18 0a1 1 0 01-1 1h-2a1 1 0 010-2h2a1 1 0 011 1zM5.636 6.05a1 1 0 010-1.414L4.222 3.222a1 1 0 10-1.414 1.414L4.222 6.05a1 1 0 001.414 0zm12.728 11.314a1 1 0 010 1.414l-1.414 1.414a1 1 0 01-1.414-1.414l1.414-1.414a1 1 0 011.414 0zM5.636 17.95a1 1 0 01-1.414 0l-1.414-1.414a1 1 0 011.414-1.414l1.414 1.414a1 1 0 010 1.414zM18.364 6.05a1 1 0 001.414 0l1.414-1.414a1 1 0 00-1.414-1.414L18.364 4.636a1 1 0 000 1.414zM12 7a5 5 0 100 10A5 5 0 0012 7z"/>
      </svg>
    </button>

    <!-- Paylaş/QR Butonu -->
    <button 
      id="share-btn" 
      class="w-7 h-7 flex items-center justify-center rounded-full text-white/70 hover:text-white hover:bg-white/5 transition-all duration-300"
      aria-label={ui.sharePage}
    >
      <Icon name="fa6-solid:share-nodes" class="w-3.5 h-3.5" />
    </button>
  </div>

  <!-- Ana İçerik Konteyneri -->
  <div id="links-page" class="w-full min-h-screen flex items-center justify-center px-4 py-20 relative">
    
    <!-- 3D Cam Efekti Kartı (Translucent Glassmorphic Main Card) -->
    <div class={linksCardClass}>
      <!-- Arka Plan Küresel Işımaları (Ambient Glowing Circles) -->
      <div class="absolute -top-40 -left-40 w-80 h-80 bg-[#f75023]/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute -bottom-40 -right-40 w-80 h-80 bg-[#1cbe59]/10 rounded-full blur-[100px] pointer-events-none"></div>

      <!-- Profil Alanı -->
      <div class="text-center w-full flex flex-col items-center mb-4">
        <!-- Fotoğraf Çerçevesi (3D Dönen Gradient) -->
        <button 
          id="profile-avatar-btn"
          class="relative w-28 h-28 mb-5 group cursor-pointer focus:outline-none"
          aria-label={ui.openPhoto}
        >
          <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#f75023] via-[#ffb324] to-[#f75023] animate-spin-slow -m-1.5 opacity-80 group-hover:opacity-100 transition-opacity duration-300 shadow-md"></div>
          <Image 
            src={data.profile.avatar} 
            alt={data.profile.name} 
            width={112}
            height={112}
            loading="eager"
            class="relative w-full h-full rounded-full object-cover border border-white/20 bg-[#23252a] group-hover:scale-105 transition-transform duration-300"
          />
        </button>

        <!-- İsim ve Doğrulama Rozeti -->
        <h1 class="text-2xl md:text-3xl font-secondary font-bold text-white flex items-center justify-center gap-1.5 drop-shadow-md mb-3 tracking-wide">
          {data.profile.name}
          <span title={ui.verifiedUser} class="inline-flex items-center">
            <svg class="w-5 h-5 fill-[#179cf0] drop-shadow-sm animate-pulse-slow" id="Layer_1" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
              <path fill="#fcfcfc" d="M148.45,68.73c-18.55,24.89-36.88,49.47-55.35,74.26-13.57-10.16-26.84-20.09-40.59-30.38,3.75-5.18,7.4-10.22,11.46-15.83,8.11,6.16,16.1,12.21,24.43,18.53,14.75-19.4,29.3-38.55,44.21-58.15,5.17,3.78,10.31,7.53,15.85,11.58Z"></path>
              <path fill="#179cf0" d="M126.22,193.94c-4-1.79-8.38-3.03-11.92-5.47-10.35-7.13-19.99-5.75-29.73,1.07-2.11,1.48-4.74,2.34-7.24,3.12-5.46,1.72-9.86,.27-13.07-4.52-2.28-3.41-4.61-6.93-6.08-10.72-3.42-8.79-9.82-12.76-18.93-13.5-3.91-.32-7.85-1.16-11.62-2.3-7.51-2.28-10.2-8.34-8.26-17.2,1.02-4.65,2.52-9.43,2.24-14.06-.22-3.66-2.26-7.61-4.53-10.64-2.96-3.96-7.03-7.07-10.48-10.68-4.81-5.04-5.3-11.17-1.01-16.59,2.77-3.51,5.84-6.92,9.3-9.72,6.71-5.41,6.94-12.32,5.74-19.86-.65-4.06-1.42-8.15-1.56-12.25-.24-6.79,1.88-9.72,8.46-11.56,4.9-1.37,9.97-2.18,14.99-3.05,5.99-1.04,11.01-3.25,13.65-9.3,1.59-3.64,3.62-7.08,5.45-10.62,4.81-9.35,11.51-11.61,20.84-6.89,3.53,1.79,6.89,3.93,10.41,5.75,4.82,2.49,9.59,2.76,14.71,.28,5.91-2.85,11.98-5.57,18.27-7.29,2.56-.7,7.04,.44,8.63,2.39,4.05,4.94,7.41,10.59,10.21,16.36,2.91,5.99,7.75,8.18,13.68,9.29,4.84,.9,9.76,1.59,14.46,2.99,7.24,2.15,10.27,7.18,9.11,14.36-.76,4.7-1.96,9.34-2.63,14.06-1.12,7.84,3.09,13.13,8.76,17.76,4.88,3.98,9.51,7.76,9.22,15.42-.23,6.11-3.23,9.86-7.22,13.3-4.97,4.28-10.18,8.58-10.58,15.5-.29,5,.82,10.14,1.79,15.13,2.15,11.16-.16,15.08-11.25,17.83-3.83,.95-7.71,1.97-11.62,2.3-8.28,.7-12.44,5.92-15.51,12.81-1.47,3.32-3.18,6.57-5.13,9.63-2.53,3.98-5.82,6.95-11.53,6.86Zm22.23-125.22c-5.54-4.05-10.68-7.8-15.85-11.58-14.9,19.6-29.46,38.75-44.21,58.15-8.33-6.32-16.31-12.38-24.43-18.53-4.06,5.61-7.7,10.65-11.46,15.83,13.75,10.3,27.02,20.23,40.59,30.38,18.48-24.79,36.8-49.36,55.35-74.26Z"></path>
            </svg>
          </span>
        </h1>

        <!-- Biyografi -->
        <p class="text-[15px] md:text-[16px] leading-relaxed text-white/80 max-w-[460px] mx-auto mb-6 font-primary font-normal tracking-wide text-center">
          {data.profile.bio}
        </p>

        <!-- Hızlı Sosyal Medya İkonları (Glow ve Hover Efektli) -->
        <div class="flex items-center justify-center gap-3.5 mt-2">
          {data.socials.map((social) => {
            const styleInfo = getLinkStyle(social.icon);
            return (
              <a 
                href={social.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                title={social.name}
                style={`
                  --hover-glow: ${styleInfo.glow};
                  --btn-idle-bg: ${styleInfo.idleBg};
                  --btn-hover-bg: ${styleInfo.hoverBg};
                  --btn-idle-border: ${styleInfo.idleBorder};
                  --btn-hover-border: ${styleInfo.hoverBorder};
                `}
                class={socialButtonClass}
              >
                <Icon name={social.icon} class="w-[18px] h-[18px]" />
              </a>
            );
          })}
        </div>
      </div>

      <!-- Bağlantı Butonları Listesi -->
      <div class="w-full max-w-[460px] flex flex-col gap-4 mt-2">
        {data.groups.map((group, groupIdx) => (
          <div class="w-full flex flex-col gap-3">
            {group.title && (
              <h2 class="text-center font-secondary text-[11px] md:text-xs font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#f75023]/80 via-[#ffb324]/80 to-[#f75023]/80 uppercase tracking-[0.3em] mt-8 mb-2">
                {group.title}
              </h2>
            )}
            {group.links.map((link, linkIdx) => {
              const styleInfo = getLinkStyle(link.icon);
              return (
                <div 
                  class="w-full translate-y-4 opacity-0 [animation:var(--animate-links-fade-in-up)]"
                  style={`animation-delay: ${(groupIdx * 3 + linkIdx) * 100}ms; animation-fill-mode: forwards;`}
                >
                  <a 
                    href={link.url} 
                    target={link.url.startsWith('http') ? "_blank" : "_self"}
                    rel="noopener noreferrer nofollow"
                    style={`
                      --hover-glow: ${styleInfo.glow};
                      --btn-idle-bg: ${styleInfo.idleBg};
                      --btn-hover-bg: ${styleInfo.hoverBg};
                      --btn-idle-border: ${styleInfo.idleBorder};
                      --btn-hover-border: ${styleInfo.hoverBorder};
                    `}
                    class={linkButtonClass}
                  >
                    {link.icon && (
                      <Icon name={link.icon} class="w-[18px] h-[18px] shrink-0 opacity-80 group-hover/item:[animation:var(--animate-icon-hover)] group-hover/item:opacity-100 transition-opacity duration-300" />
                    )}
                    <span>{link.title}</span>
                    <!-- 3D Cam Parlama Efekti (Sheen Effect) -->
                    <span class="absolute inset-0 w-full h-full rounded-xl overflow-hidden pointer-events-none">
                      <span class="absolute top-0 -left-[100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-[-25deg] sheen-element"></span>
                    </span>
                  </a>
                </div>
              );
            })}
          </div>
        ))}
      </div>

      <!-- Alt Alan (Footer) -->
      <footer class="mt-14 mb-1 text-center">
        <div class="flex items-center justify-center gap-4 text-xs font-semibold text-white/50 mb-3.5">
          <a href={lang === 'tr' ? '/' : `/${lang}/`} class="hover:text-white transition-colors duration-300">{navLabels.home}</a>
          <span class="text-white/20">•</span>
          <a href={lang === 'tr' ? '/#contact' : `/${lang}/#contact`} class="hover:text-white transition-colors duration-300">{navLabels.contact}</a>
        </div>
        <p class="text-[10px] font-semibold text-white/30 tracking-wider uppercase">
          © {new Date().getFullYear()} {data.footer}
        </p>
      </footer>

    </div>
  </div>

  <!-- Paylaşım & QR Kod Modalı (Cam Efektli Pop-up) -->
  <div 
    id="share-modal" 
    class="fixed inset-0 w-full h-full bg-black/60 backdrop-blur-md z-50 flex items-center justify-center p-4 hidden select-none"
  >
    <div 
      id="modal-card" 
      class="bg-[#2b2d33]/50 border border-white/10 rounded-3xl w-full max-w-sm p-6 relative shadow-2xl transition-all duration-300 transform scale-95 opacity-0 text-center backdrop-blur-2xl"
    >
      <!-- Kapat Butonu -->
      <button 
        id="modal-close" 
        class="absolute top-4 right-4 w-8 h-8 rounded-full flex items-center justify-center bg-white/5 text-white/60 hover:text-white hover:bg-white/10 transition-colors"
        aria-label={ui.closeModal}
      >
        <Icon name="fa6-solid:xmark" class="w-3.5 h-3.5" />
      </button>

      <!-- QR Başlık -->
      <h3 class="text-lg font-jost font-bold text-white mb-2">{data.qrTitle}</h3>
      <p class="text-xs text-white/75 mb-6">{data.qrDesc}</p>

      <!-- QR Kod Görseli -->
      <div class="bg-white p-4 rounded-xl inline-block shadow-inner mb-6">
        <img 
          src={`https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${encodeURIComponent(currentUrl)}`} 
          alt={ui.qrAlt} 
          class="w-[180px] h-[180px] select-none pointer-events-none" 
          loading="lazy"
        />
      </div>

      <!-- Kopyalama Alanı -->
      <div class="flex items-center gap-2 bg-black/30 border border-white/10 p-2.5 rounded-xl text-left">
        <input 
          type="text" 
          value={currentUrl} 
          readonly 
          class="bg-transparent border-none outline-none text-xs text-white/80 w-full overflow-hidden text-ellipsis whitespace-nowrap pl-1"
        />
        <button 
          id="copy-btn" 
          class="bg-[#f75023] hover:bg-[#d63f18] text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-all duration-300 shrink-0 shadow flex items-center gap-1.5"
          data-copied-text={data.copied}
        >
          <Icon name="fa6-regular:copy" class="w-3.5 h-3.5 copy-icon" />
          <Icon name="fa6-solid:check" class="w-3.5 h-3.5 check-icon hidden" />
          <span>{data.share}</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Polaroid Modal -->
  <div 
    id="polaroid-modal" 
    class="fixed inset-0 w-full h-full bg-black/85 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden select-none opacity-0 transition-opacity duration-[800ms]"
  >
    <!-- Polaroid Kartı -->
    <div 
      id="polaroid-card" 
      class={`${polaroidCardBaseClass} ${polaroidCardClosingClass}`}
    >
      <!-- Kapatma X Butonu (Sağ Üst Köşede) -->
      <button 
        id="polaroid-close" 
        class="absolute -top-3.5 -right-3.5 w-8 h-8 rounded-full flex items-center justify-center bg-[#fbfbf9] border border-neutral-200 text-[#1a2536] hover:bg-neutral-100 hover:text-red-500 shadow-md transition-all duration-300 focus:outline-none z-20 cursor-pointer"
        aria-label={ui.closePhoto}
      >
        <Icon name="fa6-solid:xmark" class="w-3.5 h-3.5" />
      </button>

      <!-- Polaroid Resim Çerçevesi -->
      <div class={polaroidImageWrapClass}>
        <!-- Vintage Vignette Overlay -->
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/10 z-10 pointer-events-none"></div>
        <div class="absolute inset-0 shadow-[inset_0_0_40px_rgba(0,0,0,0.3)] z-10 pointer-events-none"></div>
        <Image 
          src={data.profile.avatar} 
          alt={data.profile.name} 
          width={400}
          height={400}
          loading="lazy"
          class={polaroidImageClass}
        />
      </div>
      
      <!-- Polaroid El Yazısı Alt Kısım -->
      <div class="mt-4 sm:mt-6 text-center select-none">
        <p class={caveatTextClass}>
          {ui.photoCaption}
        </p>
      </div>
    </div>
  </div>
</LinksLayout>

<script is:inline define:vars={{ polaroidCardOpenClass, polaroidCardClosingClass, ui }}>
  (() => {
    const initLinksPage = () => {
      const linksRoot = document.getElementById('links-page');
      if (!(linksRoot instanceof HTMLElement) || linksRoot.dataset.linksBound === 'true') return;
      linksRoot.dataset.linksBound = 'true';

      const themeToggle = document.getElementById('theme-toggle');
      const shareBtn = document.getElementById('share-btn');
      const shareModal = document.getElementById('share-modal');
      const modalCard = document.getElementById('modal-card');
      const modalClose = document.getElementById('modal-close');
      const copyBtn = document.getElementById('copy-btn');
      const profileAvatarBtn = document.getElementById('profile-avatar-btn');
      const polaroidModal = document.getElementById('polaroid-modal');
      const polaroidCard = document.getElementById('polaroid-card');
      const polaroidClose = document.getElementById('polaroid-close');
      const polaroidOpenClasses = `${polaroidCardOpenClass}`.trim().split(/\s+/);
      const polaroidClosingClasses = `${polaroidCardClosingClass}`.trim().split(/\s+/);

      function updateThemeToggleIcon() {
        const isDark = document.documentElement.classList.contains('dark');
        const moon = document.getElementById('icon-moon');
        const sun = document.getElementById('icon-sun');
        if (isDark) {
          moon?.classList.add('hidden');
          sun?.classList.remove('hidden');
        } else {
          moon?.classList.remove('hidden');
          sun?.classList.add('hidden');
        }
      }

      function triggerSpin(btn) {
        if (!btn) return;
        const svgs = btn.querySelectorAll('svg');
        svgs.forEach(svg => {
          if (svg.clientWidth > 0 || svg.clientHeight > 0) {
            svg.classList.remove('animate-theme-spin');
            void svg.getBoundingClientRect();
            svg.classList.add('animate-theme-spin');

            svg.addEventListener('animationend', () => {
              svg.classList.remove('animate-theme-spin');
            }, { once: true });
          }
        });
      }

      themeToggle?.addEventListener('click', (e) => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeToggleIcon();
        triggerSpin(e.currentTarget);
      });

      updateThemeToggleIcon();

      function openModal() {
        shareModal?.classList.remove('hidden');
        setTimeout(() => {
          modalCard?.classList.remove('scale-95', 'opacity-0');
          modalCard?.classList.add('scale-100', 'opacity-100');
        }, 10);
      }

      function closeModal() {
        modalCard?.classList.remove('scale-100', 'opacity-100');
        modalCard?.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          shareModal?.classList.add('hidden');
        }, 250);
      }

      shareBtn?.addEventListener('click', () => {
        const shareUrl = window.location.href.replace(window.location.origin, 'https://www.serdaryavuz.com');
        if (navigator.share) {
          navigator.share({
            title: document.title,
            text: ui.shareTitle,
            url: shareUrl
          }).catch(err => {
            console.log('Share failed or cancelled:', err);
          });
        } else {
          openModal();
        }
      });

      modalClose?.addEventListener('click', closeModal);
      shareModal?.addEventListener('click', (e) => {
        if (e.target === shareModal) {
          closeModal();
        }
      });

      copyBtn?.addEventListener('click', () => {
        const input = copyBtn.previousElementSibling;
        if (input) {
          navigator.clipboard.writeText(input.value).then(() => {
            const textSpan = copyBtn.querySelector('span');
            const copyIcon = copyBtn.querySelector('.copy-icon');
            const checkIcon = copyBtn.querySelector('.check-icon');
            const originalText = textSpan ? textSpan.innerText : '';
            const copiedText = copyBtn.getAttribute('data-copied-text') || 'Copied!';

            if (textSpan) {
              textSpan.innerText = copiedText;
              copyIcon?.classList.add('hidden');
              checkIcon?.classList.remove('hidden');
              copyBtn.classList.remove('bg-[#f75023]');
              copyBtn.classList.add('bg-[#1cbe59]');

              setTimeout(() => {
                textSpan.innerText = originalText;
                copyIcon?.classList.remove('hidden');
                checkIcon?.classList.add('hidden');
                copyBtn.classList.remove('bg-[#1cbe59]');
                copyBtn.classList.add('bg-[#f75023]');
              }, 2000);
            }
          }).catch(err => {
            console.error(ui.copyError, err);
          });
        }
      });

      document.querySelectorAll('[data-lang-link]').forEach(link => {
        link.addEventListener('click', () => {
          const targetLang = link.getAttribute('data-lang-link');
          if (targetLang) {
            localStorage.setItem('lang-preference', targetLang);
          }
        });
      });

      function openPolaroid() {
        if (!polaroidModal || !polaroidCard) return;
        polaroidModal.classList.remove('hidden');
        void polaroidModal.offsetWidth;
        polaroidModal.classList.add('opacity-100');
        polaroidCard.classList.remove(...polaroidClosingClasses);
        polaroidCard.classList.add(...polaroidOpenClasses);
      }

      function closePolaroid() {
        if (!polaroidModal || !polaroidCard) return;
        polaroidModal.classList.remove('opacity-100');
        polaroidCard.classList.remove(...polaroidOpenClasses);
        polaroidCard.classList.add(...polaroidClosingClasses);
        setTimeout(() => {
          polaroidModal.classList.add('hidden');
        }, 800);
      }

      profileAvatarBtn?.addEventListener('click', openPolaroid);
      polaroidClose?.addEventListener('click', (e) => {
        e.stopPropagation();
        closePolaroid();
      });
      polaroidModal?.addEventListener('click', (e) => {
        if (e.target === polaroidModal) {
          closePolaroid();
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLinksPage, { once: true });
    } else {
      initLinksPage();
    }

    document.addEventListener('astro:page-load', initLinksPage);
  })();
</script>
