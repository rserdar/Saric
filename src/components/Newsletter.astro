---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);
---

<section class="pb-[120px] md:pb-[170px]">
  <div class="container">
    <div class="bg-[url('/img/subscribe/dots.jpg')] relative rounded-xl py-[90px] px-7 md:px-[86px] overflow-hidden">
      <div class="bg-[#8067f0]/90 absolute inset-0 rounded-xl"></div>
      <div class="grid grid-cols-1 lg:grid-cols-2 relative gap-y-10 lg:gap-y-0 items-center gap-4">
        <div class="text-white" data-animate="fade-in-left" data-animate-duration="1s">
          <p class="md:text-[21px] text-[19px] font-medium font-secondary">{content.newsletter.tag}</p>
          <h4 class="mt-4 text-[35px] md:text-5xl">{content.newsletter.title}</h4>
          <p class="mt-4 text-lg leading-8 max-w-[560px]">{content.newsletter.text}</p>
        </div>
        <div class="lg:text-right" data-animate="fade-in-right" data-animate-duration="1s">
          <a href="/img/cv/cv.pdf" download class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-[17px] font-semibold text-[#8067f0] transition-transform duration-300 hover:-translate-y-1">
            {content.newsletter.cta}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
