---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';
import { Image } from 'astro:assets';
import { siteAssets } from '../data/siteAssets';
import paperDividerRaw from '../assets/img/svg/paper.svg?raw';
import heroBgLight from '../assets/img/slider/1.webp';
import heroBgDark from '../assets/img/slider/2.webp';
import { Icon } from 'astro-icon/components';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props as Props;
const content = await getSiteContent(lang);
const skillPositions = [
  { bg: "bg-white",      pos: "-left-6 bottom-16 xl:-left-9 xl:bottom-20" },
  { bg: "bg-[#323330]",  pos: "-right-5 top-18 xl:-right-8 xl:top-22" },
  { bg: "bg-[#1e1e1e]",  pos: "left-0 top-3 xl:-left-2 xl:top-2" },
];

const targetPhrase = 'batmanPhrase' in content.hero ? content.hero.batmanPhrase : 'mask at night.';
const bioParts = content.hero.bio.split(targetPhrase);
const paperDividerMarkup = paperDividerRaw
  .replace(/<\?xml[\s\S]*?\?>/i, '')
  .replace(/<!DOCTYPE[\s\S]*?>/i, '')
  .replace(/fill="#fff"/gi, 'fill="currentColor"')
  .replace(/<svg\b/i, '<svg class="block h-auto w-full" preserveAspectRatio="xMidYMid meet"');

const heroTypedWords = content.hero.typedWords.join(', ');
const highlightLocationFirst = 'highlightLocationFirst' in content.hero && content.hero.highlightLocationFirst;
const batmanOffsetClass = lang === 'tr' ? 'left-[118%]' : 'left-[135%]';
const primaryButtonClass = "relative z-10 inline-block overflow-hidden rounded-full border-2 border-custom px-[35px] py-[14px] font-secondary font-medium text-white transition-all duration-300 before:absolute before:inset-x-[-5px] before:bottom-[-5px] before:z-[-1] before:h-[112%] before:bg-custom before:transition-[height] before:duration-300 hover:text-black hover:before:h-0 md:px-12 dark:text-white";
const socialButtonClass = "flex h-10 w-10 items-center justify-center rounded-full border-2 border-neutral-300 bg-neutral-500/5 text-dark transition-all duration-300 hover:scale-105 hover:border-custom hover:bg-custom hover:text-white active:scale-95 dark:border-white/20 dark:bg-white/5 dark:text-white dark:hover:text-white";
---

<section
  class="relative flex items-center overflow-hidden py-24 lg:min-h-screen lg:py-32"
  id="home"
>
  <Image
    aria-hidden="true"
    alt=""
    src={heroBgLight}
    class="pointer-events-none absolute inset-0 h-full w-full object-cover dark:hidden"
    widths={[768, 1280, 1920]}
    sizes="100vw"
  />
  <Image
    aria-hidden="true"
    alt=""
    src={heroBgDark}
    class="pointer-events-none absolute inset-0 hidden h-full w-full object-cover dark:block"
    widths={[768, 1280, 1920]}
    sizes="100vw"
  />
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.22),transparent_30%),radial-gradient(circle_at_top_right,rgba(255,193,205,0.10),transparent_24%),linear-gradient(180deg,rgba(245,241,232,0.34),rgba(244,239,230,0.46))] dark:hidden"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 hidden bg-[linear-gradient(180deg,rgba(43,45,51,0.04),rgba(43,45,51,0.18))] dark:block"
  ></div>

  <div class="container-wide relative z-[2]">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.02fr)_minmax(380px,0.98fr)] lg:gap-12 xl:grid-cols-[minmax(0,1fr)_minmax(430px,1fr)] xl:gap-16">

      <!-- Left: Text -->
      <div class="order-2 mx-auto max-w-[680px] lg:order-1 lg:mx-0 lg:max-w-[640px] xl:max-w-[720px]">
        <h3 class="font-secondary text-[21px] font-medium leading-[1.2] text-custom text-center lg:text-left lg:text-[28px] xl:text-[42px]">
          {content.hero.greeting}
        </h3>
        <h1 class="mb-3 text-center font-secondary text-[42px] font-medium leading-[1.08] sm:text-[54px] md:text-[64px] lg:mb-5 lg:text-left lg:text-[72px] xl:text-[92px]">
          {content.globals.name}
        </h1>
        <p class="mx-auto mb-4 max-w-[22rem] text-center text-lg font-medium leading-[1.45] sm:max-w-[32rem] lg:mx-0 lg:mb-9 lg:max-w-none lg:text-left lg:text-[21px] xl:text-[30px]">
          {highlightLocationFirst ? (
            <span class="inline-flex flex-wrap items-baseline justify-center lg:justify-start gap-x-1.5">
              <span><span class="text-[#8067f0] dark:text-[#f0c45c]">{content.globals.location}</span>'da yaşayan bir</span>
              <span class="inline-flex items-baseline whitespace-nowrap">
                <span class="typer text-[#1cbe59] inline font-medium" id="main" data-words={heroTypedWords} data-delay="100" data-colors="#1cbe59,#8067f0,#f75023,#ffb324"></span><span class="cursor text-[#1cbe59] inline font-medium" data-owner="main" data-cursor-display="_"></span>
              </span>
            </span>
          ) : (
            <span class="inline-flex flex-wrap items-baseline justify-center lg:justify-start gap-x-1.5">
              {content.hero.typedPrefix && <span>{content.hero.typedPrefix}</span>}
              <span class="inline-flex items-baseline whitespace-nowrap">
                <span class="typer text-[#1cbe59] inline font-medium" id="main" data-words={heroTypedWords} data-delay="100" data-colors="#1cbe59,#8067f0,#f75023,#ffb324"></span><span class="cursor text-[#1cbe59] inline font-medium" data-owner="main" data-cursor-display="_"></span>
              </span>
              {content.hero.typedSuffix && <span>{content.hero.typedSuffix}</span>}
              <span class="text-[#8067f0] dark:text-[#f0c45c]">{content.globals.location}</span>
            </span>
          )}
        </p>
        <div class="mx-auto mb-[30px] max-w-[640px] overflow-visible lg:ml-0 lg:mb-[42px] xl:max-w-[690px]">
          <p class="select-text text-center text-base leading-[1.52] text-muted dark:text-white lg:text-left lg:text-[18px] xl:text-[23px]">
            {bioParts[0]}
            {bioParts.length > 1 && (
              <span class="relative inline-block group/batman overflow-visible whitespace-nowrap isolate">
                {targetPhrase}
                <!-- Classic Oval Batman Logo SVG Background from batman-2.svg -->
                <span class={`absolute ${batmanOffsetClass} top-[30%] -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none z-[-1] overflow-visible block`}>
                  <svg
                     viewBox="0 0 1.02491 0.556357"
                     class="w-[50px] transform -rotate-12 text-[#ffb324] opacity-[0.33] transition-all duration-500 group-hover/batman:scale-105 group-hover/batman:rotate-[-8deg] sm:w-[60px] md:w-[70px] xl:w-[85px]"
                     fill="currentColor"
                     aria-hidden="true"
                  >
                    <path d="M0.492773 0l0.0244553 0c0.0280379,0.000497587 0.0560834,0.00159228 0.0840126,0.00421188 0.0625031,0.00589449 0.124507,0.0183372 0.183948,0.0386801 0.0246956,0.00839774 0.0489718,0.0180923 0.0723507,0.0296929 0.0206307,0.0100206 0.0403597,0.0218173 0.0593124,0.0347147 0.0177478,0.0118349 0.0336154,0.0261777 0.0491861,0.0406858 0.00910508,0.00882796 0.019484,0.0224664 0.0266569,0.0328515 0.0103023,0.014724 0.0184306,0.0309851 0.0238092,0.0481419 0.00781135,0.025576 0.0105397,0.0430528 0.00664011,0.0697449 -0.00240985,0.0176743 -0.00782054,0.0349 -0.015664,0.0509085 -0.0284926,0.0572945 -0.0729248,0.0919296 -0.126931,0.122091 -0.0220071,0.0124917 -0.0452146,0.0227221 -0.0687053,0.0320844 -0.0501017,0.0195253 -0.102517,0.032755 -0.155558,0.041312 -0.0401805,0.00644873 -0.0808158,0.0101064 -0.121508,0.010728l0.00265635 0.000509835 -0.0514551 0c-0.00845286,-0.000978333 -0.0169991,-0.000713463 -0.0254948,-0.00121105 -0.0336017,-0.00133506 -0.0670334,-0.00550867 -0.10018,-0.0111092 -0.0241429,-0.00409399 -0.0481113,-0.00920306 -0.0717919,-0.015442 -0.0252238,-0.00665848 -0.0502073,-0.0143489 -0.074485,-0.0239332 -0.0215784,-0.00841611 -0.0425904,-0.0182392 -0.063019,-0.0291464 -0.0198315,-0.0105672 -0.0391165,-0.0222659 -0.0569944,-0.0359135 -0.00930105,-0.00703971 -0.0178948,-0.0149445 -0.0270182,-0.0221924 -0.00844673,-0.00756179 -0.0155171,-0.0164571 -0.0227099,-0.025181 -0.0113787,-0.0135864 -0.0210487,-0.0285982 -0.0285554,-0.0446558 -0.00647935,-0.0137472 -0.0117783,-0.0281986 -0.0139294,-0.0432977 -0.00100283,-0.00630175 -0.00134119,-0.0126709 -0.00180203,-0.0190262l0 -0.0151175c0.000405725,-0.00532342 0.000639973,-0.0106667 0.00137793,-0.0159534 0.00138865,-0.0112256 0.00454871,-0.0221556 0.00858759,-0.0326922 0.00761079,-0.0200382 0.0164939,-0.035517 0.0298032,-0.0521196 0.0127199,-0.0159902 0.0271483,-0.0306146 0.0429165,-0.0436116 0.0180065,-0.0148771 0.0376421,-0.0276704 0.0578548,-0.0393262 0.0239209,-0.0137273 0.0490391,-0.0252912 