---
interface Props {
  title: string;
  subtitle: string;
  description?: string;
  align?: 'left' | 'center' | 'right';
}

const { title, subtitle, description, align = 'center' } = Astro.props;

const alignClasses = {
  left: 'text-left mx-0',
  center: 'text-center mx-auto',
  right: 'text-right mx-0 ml-auto'
};
---

<div class={`w-full max-w-[680px] h-auto clear-both ${alignClasses[align]}`}>
  <span class="text-[24px] font-medium orangeText font-jost inline-block mb-[6px]">
    {title}
  </span>
  <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-tight mb-[23px] font-jost font-medium text-heading">
    {subtitle}
  </h3>
  {description && (
    <p class="text-body leading-relaxed">
      {description}
    </p>
  )}
</div>
