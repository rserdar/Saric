---
---

<div class="progressbar">
  <a href="#" class="totop" id="scroll-top"></a>
  <span class="line"></span>
</div>

<script>
  const bar = document.querySelector('.progressbar') as HTMLElement | null;
  const line = document.querySelector('.progressbar .line') as HTMLElement | null;
  const totop = document.querySelector('.progressbar .totop') as HTMLElement | null;

  if (bar && line) {
    window.addEventListener('scroll', () => {
      const scroll = window.scrollY;
      const docHeight = document.body.offsetHeight;
      const winHeight = window.innerHeight;
      const pct = Math.round((scroll / (docHeight - winHeight)) * 100);
      line.style.height = pct + '%';

      if (scroll >= 100) {
        bar.style.right = '25px';
      } else {
        bar.style.right = '-25px';
      }
    });
  }

  totop?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
