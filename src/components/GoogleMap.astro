---
// src/components/GoogleMap.astro
interface Props {
  src: string;
  title?: string;
}

const { src, title = "Location Map" } = Astro.props;
---

<iframe
  loading="lazy"
  src={src}
  title={title}
  class="block h-[375px] w-full border-0 grayscale-[0.2] transition-all duration-1000 dark:[filter:grayscale(0.6)_invert(0.9)_hue-rotate(180deg)_brightness(0.8)_contrast(1.2)]"
  sandbox="allow-scripts allow-same-origin allow-popups"
></iframe>
