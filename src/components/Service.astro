---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);
const accentClasses = ['text-custom', 'text-[#1cbe59]', 'text-[#8067f0]', 'text-[#f0c45c]'];
const glowClasses = ['shadow-[18px_0px_60px_rgba(247,80,35,0.09)]', 'shadow-[18px_0px_60px_rgba(28,190,89,0.09)]', 'shadow-[18px_0px_60px_rgba(128,103,240,0.09)]', 'shadow-[18px_0px_60px_rgba(240,196,92,0.09)]'];
---

<section class="relative pt-[120px] pb-[98px] md:pt-[178px] md:pb-[160px]" id="service">
  <div class="container relative z-10">
    <div class="grid grid-cols-1">
      <div class="text-center max-w-[760px] mx-auto">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.services.tag}</p>
        <h2 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mb-[23px] mt-1.5">{content.services.title}</h2>
        <p class="text-muted dark:text-darkmuted text-lg leading-[30px]">{content.services.description}</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 pt-[86px] gap-[25px]">
      {content.services.items.map((service, i) => (
        <article
          class={`rounded-2xl bg-white dark:bg-semilight p-7 sm:p-8 lg:p-10 transition-transform duration-300 hover:-translate-y-1 ${glowClasses[i % glowClasses.length]}`}
          data-animate={i % 2 === 0 ? 'fade-in-left' : 'fade-in-right'}
          data-animate-duration="1s"
        >
          <div class="flex items-start gap-6">
            <div class={`shrink-0 w-[74px] h-[74px] rounded-2xl bg-[#f5f5f7] dark:bg-[#3a3c42] flex items-center justify-center ${accentClasses[i % accentClasses.length]}`}>
              <span class="w-10 h-10 block [&_svg]:w-full [&_svg]:h-full" set:html={service.icon}></span>
            </div>
            <div>
              <h3 class="text-[24px] md:text-[28px] leading-[1.3] font-secondary font-medium">{service.title}</h3>
              <p class="mt-4 text-muted dark:text-darkmuted text-[17px] leading-[30px]">{service.text}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
  <div class="top-[300px] left-0 absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/service/5.png" alt="" class="brush-float-lr" />
  </div>
  <div class="top-[72px] right-[10px] absolute hidden lg:block xl:right-[24px]" data-animate="zoom-in" data-animate-duration="1s">
    <img src="/img/brushes/service/6.png" alt="" class="brush-float-reverse" />
  </div>
</section>
