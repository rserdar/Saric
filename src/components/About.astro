---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';
import { getEntry, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props as Props;
const content = await getSiteContent(lang);
const aboutEntry = await getEntry('localized', `${lang}/about`);
const renderedAbout = aboutEntry ? await render(aboutEntry) : null;
const AboutBody = renderedAbout?.Content;

const sectionCopy = {
  tr: {
    notebookLabel: 'Kişisel Notlar',
    notebookTitle: 'Haydi Başlayalım',
    notebookIntro: 'Sahada daha güvenli ve düzenli sistemler kurarken, masa başında dijital fikirler geliştirmeyi seviyorum.',
    tape: 'Not Defteri',
    sideTitle: 'Biraz da benden',
    statYearsHint: 'kurumsal ritim',
    statCertHint: 'uluslararası yetkinlik',
    stickerTitle: 'İlgi Alanları',
    pinLabel: 'Şu sıralar',
  },
  en: {
    notebookLabel: 'Personal Notes',
    notebookTitle: "Let's Begin",
    notebookIntro: 'I enjoy building safer systems in the field and digital ideas at the desk.',
    tape: 'Notebook',
    sideTitle: 'A bit more personal',
    statYearsHint: 'steady rhythm',
    statCertHint: 'global credentials',
    stickerTitle: 'Interests',
    pinLabel: 'Current mode',
  },
  bs: {
    notebookLabel: 'Lične Bilješke',
    notebookTitle: 'Hajde da Počnemo',
    notebookIntro: 'Volim graditi sigurnije sisteme na terenu i digitalne ideje za stolom.',
    tape: 'Bilježnica',
    sideTitle: 'Još malo o meni',
    statYearsHint: 'stalan ritam',
    statCertHint: 'međunarodna stručnost',
    stickerTitle: 'Interesovanja',
    pinLabel: 'Trenutno',
  },
} as const;

const interestSets = {
  tr: [
    { title: 'Oyun', icon: 'fa6-solid:gamepad', accent: '#f75023', shadow: 'rgba(247,80,35,0.20)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Co-op' },
    { title: 'Futbol', icon: 'fa6-solid:futbol', accent: '#1cbe59', shadow: 'rgba(28,190,89,0.20)', rotation: 'rotate-3', size: 'md:col-span-1', emoji: 'Maç günü' },
    { title: 'Seyahat', icon: 'fa6-solid:suitcase-rolling', accent: '#0ea5e9', shadow: 'rgba(14,165,233,0.22)', rotation: '-rotate-2', size: 'md:col-span-2', emoji: 'Yeni rota' },
    { title: 'Sinema', icon: 'fa6-solid:clapperboard', accent: '#8067f0', shadow: 'rgba(128,103,240,0.18)', rotation: 'rotate-6', size: 'md:col-span-1', emoji: 'Gece seansı' },
    { title: 'Mutfak', icon: 'fa6-solid:kitchen-set', accent: '#ffb324', shadow: 'rgba(255,179,36,0.22)', rotation: '-rotate-3', size: 'md:col-span-1', emoji: 'Lezzet laboratuvarı' },
    { title: 'Fotoğraf', icon: 'fa6-solid:camera-retro', accent: '#f97316', shadow: 'rgba(249,115,22,0.22)', rotation: 'rotate-2', size: 'md:col-span-1', emoji: 'Kare avı' },
    { title: 'Atlar', icon: 'fa6-solid:horse', accent: '#64748b', shadow: 'rgba(100,116,139,0.18)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Sakin enerji' },
    { title: 'Yüzme', icon: 'fa6-solid:person-swimming', accent: '#06b6d4', shadow: 'rgba(6,182,212,0.20)', rotation: 'rotate-3', size: 'md:col-span-2', emoji: 'Reset modu' },
  ],
  en: [
    { title: 'Gaming', icon: 'fa6-solid:gamepad', accent: '#f75023', shadow: 'rgba(247,80,35,0.20)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Co-op' },
    { title: 'Football', icon: 'fa6-solid:futbol', accent: '#1cbe59', shadow: 'rgba(28,190,89,0.20)', rotation: 'rotate-3', size: 'md:col-span-1', emoji: 'Matchday' },
    { title: 'Travel', icon: 'fa6-solid:suitcase-rolling', accent: '#0ea5e9', shadow: 'rgba(14,165,233,0.22)', rotation: '-rotate-2', size: 'md:col-span-2', emoji: 'New route' },
    { title: 'Cinema', icon: 'fa6-solid:clapperboard', accent: '#8067f0', shadow: 'rgba(128,103,240,0.18)', rotation: 'rotate-6', size: 'md:col-span-1', emoji: 'Late show' },
    { title: 'Cooking', icon: 'fa6-solid:kitchen-set', accent: '#ffb324', shadow: 'rgba(255,179,36,0.22)', rotation: '-rotate-3', size: 'md:col-span-1', emoji: 'Flavor lab' },
    { title: 'Photography', icon: 'fa6-solid:camera-retro', accent: '#f97316', shadow: 'rgba(249,115,22,0.22)', rotation: 'rotate-2', size: 'md:col-span-1', emoji: 'Frame hunt' },
    { title: 'Horses', icon: 'fa6-solid:horse', accent: '#64748b', shadow: 'rgba(100,116,139,0.18)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Calm energy' },
    { title: 'Swimming', icon: 'fa6-solid:person-swimming', accent: '#06b6d4', shadow: 'rgba(6,182,212,0.20)', rotation: 'rotate-3', size: 'md:col-span-2', emoji: 'Reset mode' },
  ],
  bs: [
    { title: 'Gaming', icon: 'fa6-solid:gamepad', accent: '#f75023', shadow: 'rgba(247,80,35,0.20)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Co-op' },
    { title: 'Fudbal', icon: 'fa6-solid:futbol', accent: '#1cbe59', shadow: 'rgba(28,190,89,0.20)', rotation: 'rotate-3', size: 'md:col-span-1', emoji: 'Dan utakmice' },
    { title: 'Putovanja', icon: 'fa6-solid:suitcase-rolling', accent: '#0ea5e9', shadow: 'rgba(14,165,233,0.22)', rotation: '-rotate-2', size: 'md:col-span-2', emoji: 'Nova ruta' },
    { title: 'Film', icon: 'fa6-solid:clapperboard', accent: '#8067f0', shadow: 'rgba(128,103,240,0.18)', rotation: 'rotate-6', size: 'md:col-span-1', emoji: 'Kasna projekcija' },
    { title: 'Kuhinja', icon: 'fa6-solid:kitchen-set', accent: '#ffb324', shadow: 'rgba(255,179,36,0.22)', rotation: '-rotate-3', size: 'md:col-span-1', emoji: 'Laboratorij okusa' },
    { title: 'Fotografija', icon: 'fa6-solid:camera-retro', accent: '#f97316', shadow: 'rgba(249,115,22,0.22)', rotation: 'rotate-2', size: 'md:col-span-1', emoji: 'Lov na kadar' },
    { title: 'Konji', icon: 'fa6-solid:horse', accent: '#64748b', shadow: 'rgba(100,116,139,0.18)', rotation: '-rotate-6', size: 'md:col-span-1', emoji: 'Mirna energija' },
    { title: 'Plivanje', icon: 'fa6-solid:person-swimming', accent: '#06b6d4', shadow: 'rgba(6,182,212,0.20)', rotation: 'rotate-3', size: 'md:col-span-2', emoji: 'Reset mod' },
  ],
} as const;

const copy = sectionCopy[lang] ?? sectionCopy.tr;
const interests = interestSets[lang] ?? interestSets.tr;
const notebookPins = [
  { label: content.hero.typedWords[1], color: 'bg-[#f75023]/12 text-[#f75023] ring-[#f75023]/15' },
  { label: content.hero.typedWords[2], color: 'bg-[#8067f0]/12 text-[#8067f0] ring-[#8067f0]/15' },
  { label: content.globals.location, color: 'bg-[#1cbe59]/12 text-[#1cbe59] ring-[#1cbe59]/15' },
];
const notebookLinesClass = "bg-[#fffdf8] bg-[linear-gradient(to_bottom,rgba(58,160,229,0.12)_1px,transparent_1px)] [background-size:100%_2.05rem] [background-position:0_1.35rem] dark:bg-[#2b2e36] dark:bg-[linear-gradient(to_bottom,rgba(125,211,252,0.08)_1px,transparent_1px)]";
const tapeBaseClass = "pointer-events-none absolute z-30 backdrop-blur-[2px] [clip-path:polygon(0%_0%,100%_0%,97%_20%,100%_38%,96%_56%,100%_74%,97%_90%,100%_100%,0%_100%,3%_84%,0%_66%,4%_48%,0%_30%,3%_14%)] [filter:drop-shadow(0_3px_8px_rgba(0,0,0,0.12))] bg-[linear-gradient(to_bottom,rgba(248,246,238,0.85)_0%,rgba(238,234,218,0.70)_50%,rgba(248,246,238,0.80)_100%)] dark:bg-[linear-gradient(to_bottom,rgba(210,210,228,0.30)_0%,rgba(188,188,208,0.22)_50%,rgba(210,210,228,0.28)_100%)] dark:[filter:drop-shadow(0_3px_8px_rgba(0,0,0,0.35))]";
const tapeKraftClass = "pointer-events-none absolute z-30 [clip-path:polygon(0%_0%,100%_0%,98%_17%,100%_36%,97%_54%,100%_71%,98%_88%,100%_100%,0%_100%,2%_90%,0%_74%,3%_58%,0%_40%,2%_22%)] [filter:drop-shadow(0_3px_8px_rgba(0,0,0,0.14))] bg-[linear-gradient(to_bottom,rgba(224,214,162,0.88)_0%,rgba(204,194,144,0.74)_50%,rgba(224,214,162,0.84)_100%)] dark:bg-[linear-gradient(to_bottom,rgba(202,193,144,0.40)_0%,rgba(182,173,126,0.30)_50%,rgba(202,193,144,0.36)_100%)] dark:[filter:drop-shadow(0_3px_8px_rgba(0,0,0,0.32))]";

const doodles = {
  underline: `<svg viewBox="0 0 180 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 22C38 14 70 12 98 14C124 16 146 18 172 10" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  sparkle: `<svg viewBox="0 0 74 74" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M37 6V24" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M37 50V68" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M6 37H24" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M50 37H68" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M16 16L26 26" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M48 48L58 58" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M58 16L48 26" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><path d="M26 48L16 58" stroke="currentColor" stroke-width="5" stroke-linecap="round"/></svg>`,
};

---

<section class="relative overflow-hidden bg-transparent pt-16 pb-20 dark:bg-transparent md:pt-[112px] md:pb-[140px]" id="about">
  <div aria-hidden="true" class="absolute left-1/2 top-32 h-72 w-72 -translate-x-[120%] rounded-full bg-[#f75023]/10 blur-3xl dark:bg-[#f75023]/8"></div>
  <div aria-hidden="true" class="absolute right-0 top-48 h-96 w-96 translate-x-1/3 rounded-full bg-[#0ea5e9]/10 blur-3xl dark:bg-[#0ea5e9]/8"></div>

  <div class="container relative">
    <div class="mx-auto max-w-[1180px]">
      <div class="mb-10 md:mb-14" data-animate="fade-in-left" data-animate-duration="1s">
        <p class="text-custom text-[20px] font-medium font-secondary md:text-2xl">{content.about.tag}</p>
        <h3 class="mt-1.5 text-[30px] leading-[1.15] sm:text-[38px] md:text-[50px]">{content.about.title}</h3>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-start lg:gap-12">
        <div class="relative" data-animate="fade-in-up" data-animate-duration="0.9s">
          <div aria-hidden="true" class="pointer-events-none absolute -left-3 top-0 z-10 hidden w-12 -rotate-[18deg] text-[#f75023]/60 lg:block" set:html={doodles.sparkle}></div>

          <span aria-hidden="true" class={`${tapeBaseClass} -top-3.5 left-8 h-7 w-[88px] -rotate-[11deg]`}></span>
          <span aria-hidden="true" class={`${tapeKraftClass} -top-2.5 right-12 h-6 w-[74px] rotate-[9deg]`}></span>
          <span aria-hidden="true" class={`${tapeBaseClass} -bottom-3 right-28 h-5 w-[62px] -rotate-[6deg]`}></span>

          <div class="relative overflow-hidden rounded-[36px] border border-black/7 bg-white/90 px-5 py-6 shadow-[0_30px_80px_rgba(15,23,42,0.08)] backdrop-blur-sm dark:border-white/10 dark:bg-[#30323a]/92 md:px-8 md:py-8">
            <div class="mb-6 flex flex-wrap items-center gap-3 border-b border-dashed border-black/10 pb-5 dark:border-white/10">
              <span class="inline-flex rounded-full bg-[#f75023]/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.28em] text-[#f75023]">{copy.notebookLabel}</span>
              <span class="ml-auto inline-flex items-center gap-2 rounded-full border border-black/8 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.2em] text-muted dark:border-white/10 dark:text-darkmuted">
                <span class="h-2 w-2 rounded-full bg-[#1cbe59]"></span>
                {copy.tape}
              </span>
            </div>

            <div class="mb-6 flex flex-wrap gap-2">
              {notebookPins.map((pin) => (
                <span class={`inline-flex rounded-full px-3 py-1 text-xs font-semibold ring-1 ${pin.color}`}>{pin.label}</span>
              ))}
            </div>

            <div class="space-y-5">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.22em] text-muted dark:text-darkmuted">{copy.pinLabel}</p>
                <h4 class="mt-2 font-secondary text-[32px] font-semibold leading-[1.02] text-dark dark:text-white md:text-[42px]">
                  {copy.notebookTitle}
                </h4>
                <p class="mt-3 max-w-[58ch] text-[15px] leading-7 text-muted dark:text-darkmuted md:text-base">
                  {copy.notebookIntro}
                </p>
              </div>

              {AboutBody && (
                <div class={`about-copy relative max-w-[68ch] space-y-4 rounded-[28px] border border-black/6 px-5 py-5 text-[15px] leading-7 text-semilight shadow-[inset_0_1px_0_rgba(255,255,255,0.8)] dark:border-white/8 dark:text-darkmuted md:px-7 md:py-7 md:text-base [&_p+p]:mt-4 [&_strong]:font-bold [&_strong]:text-inherit ${notebookLinesClass}`}>
                  <span aria-hidden="true" class="pointer-events-none absolute bottom-0 left-7 top-0 hidden w-px bg-[#f75023]/20 md:block"></span>
                  <AboutBody />
                </div>
              )}
            </div>

            <div class="mt-7 grid gap-4 sm:grid-cols-2">
              <div class="rounded-[24px] border border-black/7 bg-[linear-gradient(135deg,rgba(247,80,35,0.08),rgba(255,255,255,0.95))] p-5 dark:border-white/10 dark:bg-[linear-gradient(135deg,rgba(247,80,35,0.15),rgba(255,255,255,0.03))]">
                <p class="font-secondary text-[42px] font-bold leading-none text-dark dark:text-white">10+</p>
                <p class="mt-2 text-sm font-semibold text-dark dark:text-white">{content.about.stats.yearsLabel}</p>
                <p class="mt-1 text-xs uppercase tracking-[0.18em] text-muted dark:text-darkmuted">{copy.statYearsHint}</p>
              </div>
              <div class="rounded-[24px] border border-black/7 bg-[linear-gradient(135deg,rgba(128,103,240,0.08),rgba(255,255,255,0.95))] p-5 dark:border-white/10 dark:bg-[linear-gradient(135deg,rgba(128,103,240,0.14),rgba(255,255,255,0.03))]">
                <p class="font-secondary text-[42px] font-bold leading-none text-dark dark:text-white">2</p>
                <p class="mt-2 text-sm font-semibold text-dark dark:text-white">{content.about.stats.certificationsLabel}</p>
                <p class="mt-1 text-xs uppercase tracking-[0.18em] text-muted dark:text-darkmuted">{copy.statCertHint}</p>
              </div>
            </div>
          </div>
        </div>

        <aside class="relative" data-animate="fade-in-right" data-animate-duration="0.9s">
          <span aria-hidden="true" class={`${tapeKraftClass} -top-3.5 left-10 h-7 w-[80px] rotate-[10deg]`}></span>
          <span aria-hidden="true" class={`${tapeBaseClass} -top-3 right-8 h-6 w-[70px] -rotate-[13deg]`}></span>
          <span aria-hidden="true" class={`${tapeKraftClass} -bottom-2.5 left-14 h-5 w-[66px] rotate-[5deg]`}></span>

          <div class="relative rounded-[36px] border border-black/7 bg-white/80 p-5 shadow-[0_24px_70px_rgba(15,23,42,0.08)] backdrop-blur-sm dark:border-white/10 dark:bg-[#32353d]/88 md:p-7">
            <div class="mb-6 flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.22em] text-[#3aa0e5]">{copy.sideTitle}</p>
                <h4 class="mt-2 font-secondary text-[28px] font-bold leading-tight text-dark dark:text-white">{copy.stickerTitle}</h4>
              </div>
              <div class="hidden rounded-[18px] border border-[#3aa0e5]/20 bg-[#3aa0e5]/8 p-3 text-[#3aa0e5] md:flex">
                <Icon name="fa6-solid:code" class="h-7 w-7" />
              </div>
            </div>

            <div aria-hidden="true" class="pointer-events-none absolute left-8 top-[82px] z-10 hidden w-28 text-[#3aa0e5]/70 md:block" set:html={doodles.underline}></div>
            <div aria-hidden="true" class="pointer-events-none absolute right-20 top-7 z-10 hidden w-12 rotate-6 text-[#8067f0]/65 xl:block" set:html={doodles.sparkle}></div>

            <div class="grid grid-cols-2 gap-4 md:auto-rows-[138px]">
              {interests.map((item, index) => (
                <div
                  class={`${item.rotation} ${item.size} group relative flex h-full min-h-[128px] flex-col justify-between overflow-hidden rounded-[28px] border border-white/70 bg-white px-4 py-4 text-dark shadow-[0_18px_40px_rgba(15,23,42,0.08),0_4px_0_color-mix(in_srgb,var(--sticker-accent)_58%,white_42%)] transition-all duration-300 hover:-translate-y-1 hover:rotate-0 dark:border-white/10 dark:bg-[#2a2d35] dark:text-white dark:shadow-[0_18px_42px_rgba(0,0,0,0.22),0_4px_0_color-mix(in_srgb,var(--sticker-accent)_48%,black_52%)]`}
                  style={`--sticker-accent:${item.accent}; --sticker-shadow:${item.shadow}; animation-delay:${index * 70}ms;`}
                  data-animate="bounce-scale"
                  data-animate-duration="0.95s"
                >
                  <span class="absolute -right-5 -top-5 h-20 w-20 rounded-full bg-[var(--sticker-accent)]/12 blur-2xl"></span>
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-[18px] border border-black/6 bg-[var(--sticker-accent)]/10 text-[var(--sticker-accent)] dark:border-white/10">
                      <Icon name={item.icon} class="h-6 w-6" />
                    </div>
                    <span class="rounded-full bg-black/4 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-muted dark:bg-white/8 dark:text-darkmuted">
                      {item.emoji}
                    </span>
                  </div>
                  <div>
                    <p class="font-secondary text-[19px] font-bold leading-tight">{item.title}</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        </aside>
      </div>
    </div>
  </div>

  <div class="absolute left-10 top-[280px] hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/about/1.png" alt="" class="brush-float" />
  </div>
  <div class="absolute bottom-[32px] right-[36px] hidden lg:block xl:right-[56px]" data-animate="fade-in-right" data-animate-duration="1s">
    <img src="/img/brushes/about/2.png" alt="" class="brush-float-reverse" />
  </div>
</section>
