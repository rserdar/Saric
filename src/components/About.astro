---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';
import { getEntry, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props as Props;
const content = await getSiteContent(lang);
const aboutEntry = await getEntry('localized', `${lang}/about`);
const renderedAbout = aboutEntry ? await render(aboutEntry) : null;
const AboutBody = renderedAbout?.Content;

const sidebarLabels = {
  tr: {
    interestsTitle: 'İlgi Alanları',
    interestsText: 'CV tarafındaki ilgi alanlarını burada biraz daha canlı ve kişisel bir dille göstermek istedim.',
  },
  en: {
    interestsTitle: 'Interests',
    interestsText: 'A little more personal and playful than a traditional CV list.',
  },
  bs: {
    interestsTitle: 'Interesovanja',
    interestsText: 'Htio sam da ovaj dio djeluje ličnije i življe od klasične CV liste.',
  },
} as const;

const interestSets = {
  tr: [
    { title: 'Oyun',      icon: 'fa6-solid:gamepad',          accent: 'from-[#f75023]/15 to-[#f75023]/5' },
    { title: 'Futbol',    icon: 'fa6-solid:futbol',            accent: 'from-[#1cbe59]/15 to-[#1cbe59]/5' },
    { title: 'Seyahat',   icon: 'fa6-solid:train-subway',      accent: 'from-[#0ea5e9]/15 to-[#0ea5e9]/5' },
    { title: 'Sinema',    icon: 'fa6-solid:film',              accent: 'from-[#8067f0]/15 to-[#8067f0]/5' },
    { title: 'Mutfak',    icon: 'fa6-solid:kitchen-set',       accent: 'from-[#ffb324]/15 to-[#ffb324]/5' },
    { title: 'Fotoğraf',  icon: 'fa6-solid:camera-retro',      accent: 'from-[#f97316]/15 to-[#f97316]/5' },
    { title: 'Atlar',     icon: 'fa6-solid:horse',             accent: 'from-[#64748b]/15 to-[#64748b]/5' },
    { title: 'Yüzme',     icon: 'fa6-solid:person-swimming',   accent: 'from-[#06b6d4]/15 to-[#06b6d4]/5' },
  ],
  en: [
    { title: 'Gaming',       icon: 'fa6-solid:gamepad',          accent: 'from-[#f75023]/15 to-[#f75023]/5' },
    { title: 'Football',     icon: 'fa6-solid:futbol',            accent: 'from-[#1cbe59]/15 to-[#1cbe59]/5' },
    { title: 'Travel',       icon: 'fa6-solid:train-subway',      accent: 'from-[#0ea5e9]/15 to-[#0ea5e9]/5' },
    { title: 'Cinema',       icon: 'fa6-solid:film',              accent: 'from-[#8067f0]/15 to-[#8067f0]/5' },
    { title: 'Cooking',      icon: 'fa6-solid:kitchen-set',       accent: 'from-[#ffb324]/15 to-[#ffb324]/5' },
    { title: 'Photography',  icon: 'fa6-solid:camera-retro',      accent: 'from-[#f97316]/15 to-[#f97316]/5' },
    { title: 'Horses',       icon: 'fa6-solid:horse',             accent: 'from-[#64748b]/15 to-[#64748b]/5' },
    { title: 'Swimming',     icon: 'fa6-solid:person-swimming',   accent: 'from-[#06b6d4]/15 to-[#06b6d4]/5' },
  ],
  bs: [
    { title: 'Gaming',      icon: 'fa6-solid:gamepad',          accent: 'from-[#f75023]/15 to-[#f75023]/5' },
    { title: 'Fudbal',      icon: 'fa6-solid:futbol',            accent: 'from-[#1cbe59]/15 to-[#1cbe59]/5' },
    { title: 'Putovanja',   icon: 'fa6-solid:train-subway',      accent: 'from-[#0ea5e9]/15 to-[#0ea5e9]/5' },
    { title: 'Film',        icon: 'fa6-solid:film',              accent: 'from-[#8067f0]/15 to-[#8067f0]/5' },
    { title: 'Kuhinja',     icon: 'fa6-solid:kitchen-set',       accent: 'from-[#ffb324]/15 to-[#ffb324]/5' },
    { title: 'Fotografija', icon: 'fa6-solid:camera-retro',      accent: 'from-[#f97316]/15 to-[#f97316]/5' },
    { title: 'Konji',       icon: 'fa6-solid:horse',             accent: 'from-[#64748b]/15 to-[#64748b]/5' },
    { title: 'Plivanje',    icon: 'fa6-solid:person-swimming',   accent: 'from-[#06b6d4]/15 to-[#06b6d4]/5' },
  ],
} as const;

const sidebar = sidebarLabels[lang] ?? sidebarLabels.tr;
const interests = interestSets[lang] ?? interestSets.tr;
---

<section class="relative pt-16 pb-20 md:pt-[112px] md:pb-[140px] dizme_tm_section" id="about">
  <div class="container">
    <div class="mx-auto max-w-[1140px]">

      <!-- Section header — same pattern as Skills -->
      <div class="mb-10 md:mb-14" data-animate="fade-in-left" data-animate-duration="1s">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.about.tag}</p>
        <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mt-1.5">{content.about.title}</h3>
      </div>

      <!-- Two-column body -->
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(300px,0.8fr)] lg:gap-16">

        <!-- Left: bio + stats -->
        <div>
          {AboutBody && (
            <div class="about-copy max-w-[68ch] space-y-4 text-[15px] leading-7 text-muted dark:text-darkmuted md:text-base">
              <AboutBody />
            </div>
          )}

          <div class="mt-10 flex flex-wrap gap-10 border-t border-black/8 pt-8 dark:border-white/10">
            <div>
              <p class="font-secondary text-[42px] font-bold leading-none text-dark dark:text-white">10+</p>
              <p class="mt-1.5 text-sm text-muted dark:text-darkmuted">{content.about.stats.yearsLabel}</p>
            </div>
            <div>
              <p class="font-secondary text-[42px] font-bold leading-none text-dark dark:text-white">2</p>
              <p class="mt-1.5 text-sm text-muted dark:text-darkmuted">{content.about.stats.certificationsLabel}</p>
            </div>
          </div>
        </div>

        <!-- Right: interests -->
        <aside>
          <div class="border-t border-black/8 pt-6 dark:border-white/10 lg:border-t-0 lg:border-l lg:pt-0 lg:pl-8 xl:pl-10">
            <h4 class="font-secondary text-[22px] font-bold text-dark dark:text-white">{sidebar.interestsTitle}</h4>
            <p class="mt-2 max-w-[32ch] text-sm leading-6 text-muted dark:text-darkmuted">{sidebar.interestsText}</p>

            <div class="mt-7 grid grid-cols-2 gap-3">
              {interests.map((item, index) => (
                <div
                  class={`group relative overflow-hidden rounded-[22px] border border-black/5 bg-gradient-to-br ${item.accent} px-4 py-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(15,23,42,0.08)] dark:border-white/10 dark:from-white/10 dark:to-white/5`}
                  data-animate="fade-in-up"
                  data-animate-duration="0.8s"
                  style={`animation-delay: ${index * 90}ms;`}
                >
                  <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/50 bg-white/70 text-dark shadow-sm transition-transform duration-300 group-hover:scale-110 dark:border-white/10 dark:bg-black/20 dark:text-white">
                    <Icon name={item.icon} class="h-5 w-5" />
                  </div>
                  <p class="mt-4 font-secondary text-[17px] font-bold text-dark dark:text-white">{item.title}</p>
                  <span class="pointer-events-none absolute -right-5 -top-5 h-16 w-16 rounded-full bg-white/30 blur-2xl dark:bg-white/10"></span>
                </div>
              ))}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <div class="absolute left-10 top-[280px] hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/about/1.png" alt="" class="brush-float" />
  </div>
  <div class="absolute -bottom-[50px] right-0 hidden lg:block" data-animate="fade-in-right" data-animate-duration="1s">
    <img src="/img/brushes/about/2.png" alt="" class="brush-float-reverse" />
  </div>
</section>

<style>
  .about-copy :global(p + p) {
    margin-top: 1rem;
  }
  .about-copy :global(strong) {
    color: inherit;
    font-weight: 700;
  }
</style>
