---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';
import { getEntry, render } from 'astro:content';
import Counter from './Counter.astro';
import { Image } from 'astro:assets';
import { siteAssets } from '../data/siteAssets';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);
const aboutEntry = await getEntry('localized', `${lang}/about`);
const renderedAbout = aboutEntry ? await render(aboutEntry) : null;
const AboutBody = renderedAbout?.Content;
---

<section class="md:pt-[112px] pt-16 relative dizme_tm_section" id="about">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[90px] items-center">

      <!-- Left: Image + counter badges -->
      <div class="relative space-y-4 md:space-y-0">
        <div>
          <Image src={siteAssets.about.light} class="mx-auto dark:hidden" alt="About" />
          <Image src={siteAssets.about.dark} class="mx-auto hidden dark:block" alt="About" />
        </div>
        <div class="top-[120px] -left-20 md:absolute" data-animate="bounce-scale" data-animate-duration="1s">
          <div class="flex gap-[17px] items-center pt-[25px] pr-[30px] pb-[21px] pl-[26px] bg-white dark:bg-semilight shadow-[25px_0px_65px_rgba(54,32,152,0.11)] rounded-lg">
            <h3 class="text-[50px] text-[#1cbe59]"><Counter end={10} />+</h3>
            <span class="name text-lg font-secondary leading-[1.3] font-medium">
              {content.about.stats.yearsLabel.split(' ').slice(0, 2).join(' ')}<br />{content.about.stats.yearsLabel.split(' ').slice(2).join(' ')}
            </span>
          </div>
        </div>
        <div class="bottom-[70px] -right-[30px] md:absolute" data-animate="bounce-scale" data-animate-duration="1s" data-animate-delay="0.2s">
          <div class="flex gap-[17px] items-center pt-[25px] pr-[30px] pb-[21px] pl-[26px] bg-white dark:bg-semilight shadow-[25px_0px_65px_rgba(54,32,152,0.11)] rounded-lg">
            <h3 class="text-[50px] text-[#6e50f0] dark:text-[#f0c45c]"><Counter end={2} /></h3>
            <span class="name text-lg font-secondary leading-[1.3] font-medium">
              ISO 9001<br />&amp; 45001
            </span>
          </div>
        </div>
      </div>

      <!-- Right: Text -->
      <div class="text-center md:text-left">
        <div class="mb-[25px] lg:max-w-[440px]">
          <p class="text-custom text-xl md:text-2xl font-medium font-secondary" data-animate="fade-in-up" data-animate-duration="1s">{content.about.tag}</p>
          <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mt-1.5" data-animate="fade-in-up" data-animate-duration="1s">{content.about.title}</h3>
        </div>
        <div class="text-muted dark:text-darkmuted lg:max-w-[560px] leading-[30px] mb-[47px] space-y-5 [&_p]:mb-5 [&_strong]:text-dark [&_strong]:dark:text-white" data-animate="fade-in-up" data-animate-duration="1s">
          {AboutBody ? (
            <AboutBody />
          ) : content.about.body?.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <p><span class="font-secondary font-medium text-dark dark:text-white">{content.about.stats.projectsLabel}:</span> {content.about.stats.projectsValue}</p>
        </div>
        <div data-animate="fade-in-up" data-animate-duration="1s">
          <a href="#contact" class="btn-custom">{content.nav.contact}</a>
        </div>
      </div>

    </div>
  </div>
  <div class="left-10 top-5 absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/about/1.png" alt="" class="brush-float" />
  </div>
  <div class="-bottom-[50px] right-0 absolute hidden lg:block" data-animate="fade-in-right" data-animate-duration="1s">
    <img src="/img/brushes/about/2.png" alt="" class="brush-float-reverse" />
  </div>
</section>
