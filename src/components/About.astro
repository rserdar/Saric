---

<section class="md:pt-[112px] pt-16 relative dizme_tm_section" id="about">
  <div class="container">
    
    <!-- Section Title (Centered) -->
    <div class="text-center mb-16 lg:mb-20 max-w-[700px] mx-auto">
      <p class="text-custom text-xl md:text-2xl font-medium font-secondary" data-animate="fade-in-up" data-animate-duration="1s">
        {lang === 'tr' ? 'Özgeçmiş' : lang === 'en' ? 'Resume' : 'Biografija'}
      </p>
      <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mt-1.5" data-animate="fade-in-up" data-animate-duration="1s">
        {lang === 'tr' ? 'Eğitim, Sertifikalar ve Deneyim' : lang === 'en' ? 'Education, Credentials & Experience' : 'Obrazovanje, Sertifikati i Iskustvo'}
      </h3>
    </div>

    <!-- Three-Column Layout (Education, Certificates & Work Experience) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-6 xl:gap-8 items-start w-full max-w-[1320px] mx-auto my-4 overflow-visible">
      
      <!-- Left Column: Education -->
      <div class="relative w-full max-w-[390px] mx-auto overflow-visible">
        <h3 class="text-xl md:text-2xl font-bold font-secondary text-dark dark:text-white mb-8 pl-4 border-l-4 border-[#1cbe59]" data-animate="fade-in-up" data-animate-duration="0.8s">
          {lang === 'tr' ? 'Eğitim Geçmişim' : lang === 'en' ? 'Education' : 'Obrazovanje'}
        </h3>
        
        <!-- Left vertical line -->
        <div class="absolute left-8 top-20 bottom-2 w-0.5 bg-neutral-200 dark:bg-white/10"></div>
        
        <div class="space-y-6 relative pl-14 pr-2">
          {educationTimeline.map((item, index) => (
            <div class="relative group" data-animate="fade-in-up" data-animate-duration="0.8s" style={`animation-delay: ${index * 120}ms;`}>
              
              <!-- Timeline node dot -->
              <div class="absolute -left-[35px] top-4 flex items-center justify-center z-10">
                <span class={`w-[20px] h-[20px] rounded-full flex items-center justify-center border-4 border-white dark:border-semidark shadow-md transition-transform duration-300 hover:scale-115 ${item.color === 'green' ? 'bg-[#1cbe59] text-white' : 'bg-[#ffb324] text-white'}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>

              <!-- Card (Compact Glassmorphic) -->
              <div class={`py-3.5 px-5 dark:bg-white/5 border dark:border-white/5 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] dark:shadow-none hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] dark:hover:bg-white/10 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group hover:border-custom/20 flex flex-col items-start text-left w-full ${item.color === 'green' ? 'bg-[#edf3ec]/90 border-[#1cbe59]/20' : 'bg-[#fdfaf2]/90 border-[#ffb324]/20'}`}>
                
                <!-- Year Badge -->
                <span class={`z-10 relative inline-block text-[11px] font-bold font-secondary px-2.5 py-0.5 rounded-full mb-1.5 shadow-sm ${item.color === 'green' ? 'bg-[#1cbe59]/10 text-[#13853c] dark:text-[#1cbe59]' : 'bg-[#ffb324]/10 text-[#b27600] dark:text-[#ffb324]'}`}>
                  {item.year}
                </span>

                <h4 class="z-10 relative font-jost text-base lg:text-[17px] font-bold text-dark dark:text-white leading-tight mb-0.5">
                  {item.school}
                </h4>
                <p class="z-10 relative text-xs lg:text-[13px] text-neutral-700 dark:text-darkmuted leading-snug">
                  {item.degree}
                </p>
                
                <!-- Watermark Background Icon -->
                {item.icon && (
                  <Icon name={item.icon} class="absolute w-20 h-20 text-neutral-500/6 dark:text-white/4 pointer-events-none z-0 transform transition-all duration-500 group-hover:scale-110 right-2 -bottom-4 translate-x-2 translate-y-2" />
                )}
                
                <span class="absolute inset-0 w-full h-full rounded-2xl overflow-hidden pointer-events-none">
                  <span class="absolute top-0 -left-[100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] group-hover:animate-sheen"></span>
                </span>

              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Middle Column: Certificates -->
      <div class="relative w-full max-w-[390px] mx-auto overflow-visible">
        <h3 class="text-xl md:text-2xl font-bold font-secondary text-dark dark:text-white mb-8 pl-4 border-l-4 border-[#8067f0] dark:border-[#f0c45c]" data-animate="fade-in-up" data-animate-duration="0.8s">
          {lang === 'tr' ? 'Sertifikalar ve Belgeler' : lang === 'en' ? 'Certificates' : 'Sertifikati'}
        </h3>
        
        <!-- Middle vertical line -->
        <div class="absolute left-8 top-20 bottom-2 w-0.5 bg-neutral-200 dark:bg-white/10"></div>
        
        <div class="space-y-6 relative pl-14 pr-2">
          {certificates.map((item, index) => (
            <div class="relative group" data-animate="fade-in-up" data-animate-duration="0.8s" style={`animation-delay: ${(index + 3) * 120}ms;`}>
              
              <!-- Timeline node dot -->
              <div class="absolute -left-[35px] top-4 flex items-center justify-center z-10">
                <span class={`w-[20px] h-[20px] rounded-full flex items-center justify-center border-4 border-white dark:border-semidark shadow-md transition-transform duration-300 hover:scale-115 ${item.color === 'blue' ? 'bg-[#8067f0] text-white' : 'bg-custom text-white'}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>

              <!-- Card (Compact Glassmorphic) -->
              <div class={`py-3.5 px-5 dark:bg-white/5 border dark:border-white/5 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] dark:shadow-none hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] dark:hover:bg-white/10 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group hover:border-custom/20 flex flex-col items-start text-left w-full ${item.color === 'blue' ? 'bg-[#f5f3f7]/90 border-[#8067f0]/20' : 'bg-[#fdf6f0]/90 border-[#f75023]/20'}`}>
                
                <!-- Year Badge -->
                <span class={`z-10 relative inline-block text-[11px] font-bold font-secondary px-2.5 py-0.5 rounded-full mb-1.5 shadow-sm ${item.color === 'blue' ? 'bg-[#8067f0]/10 text-[#5e45d1] dark:text-[#a391fc]' : 'bg-custom/10 text-[#d93c14] dark:text-custom'}`}>
                  {item.year}
                </span>

                <h4 class="z-10 relative font-jost text-base lg:text-[17px] font-bold text-dark dark:text-white leading-tight mb-0.5">
                  {item.title}
                </h4>
                <p class="z-10 relative text-xs lg:text-[13px] text-neutral-700 dark:text-darkmuted leading-snug">
                  {item.provider}
                </p>
                
                <!-- Watermark Background Icon -->
                {item.icon && (
                  <Icon name={item.icon} class="absolute w-20 h-20 text-neutral-500/6 dark:text-white/4 pointer-events-none z-0 transform transition-all duration-500 group-hover:scale-110 right-2 -bottom-4 translate-x-2 translate-y-2" />
                )}
                
                <span class="absolute inset-0 w-full h-full rounded-2xl overflow-hidden pointer-events-none">
                  <span class="absolute top-0 -left-[100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] group-hover:animate-sheen"></span>
                </span>

              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column: Work Experience -->
      <div class="relative w-full max-w-[390px] mx-auto overflow-visible">
        <h3 class="text-xl md:text-2xl font-bold font-secondary text-dark dark:text-white mb-8 pl-4 border-l-4 border-custom" data-animate="fade-in-up" data-animate-duration="0.8s">
          {lang === 'tr' ? 'İş Deneyimleri' : lang === 'en' ? 'Work Experience' : 'Radno Iskustvo'}
        </h3>
        
        <!-- Right vertical line -->
        <div class="absolute left-8 top-20 bottom-2 w-0.5 bg-neutral-200 dark:bg-white/10"></div>
        
        <div class="space-y-6 relative pl-14 pr-2">
          {workExperience.map((item, index) => (
            <div class="relative group" data-animate="fade-in-up" data-animate-duration="0.8s" style={`animation-delay: ${(index + 6) * 120}ms;`}>
              
              <!-- Timeline node dot -->
              <div class="absolute -left-[35px] top-4 flex items-center justify-center z-10">
                <span class={`w-[20px] h-[20px] rounded-full flex items-center justify-center border-4 border-white dark:border-semidark shadow-md transition-transform duration-300 hover:scale-115 ${item.color === 'cyan' ? 'bg-[#0ea5e9] text-white' : 'bg-[#fb7185] text-white'}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>

              <!-- Card (Compact Glassmorphic) -->
              <div class={`py-3.5 px-5 dark:bg-white/5 border dark:border-white/5 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] dark:shadow-none hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] dark:hover:bg-white/10 hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group hover:border-custom/20 flex flex-col items-start text-left w-full ${item.color === 'cyan' ? 'bg-[#f0f7fa]/90 border-[#0ea5e9]/20' : 'bg-[#faf2f4]/90 border-[#fb7185]/20'}`}>
                
                <!-- Year Badge -->
                <span class={`z-10 relative inline-block text-[11px] font-bold font-secondary px-2.5 py-0.5 rounded-full mb-1.5 shadow-sm ${item.color === 'cyan' ? 'bg-[#0ea5e9]/10 text-[#0369a1] dark:text-[#38bdf8]' : 'bg-[#fb7185]/10 text-[#be123c] dark:text-[#fda4af]'}`}>
                  {item.year}
                </span>

                <h4 class="z-10 relative font-jost text-base lg:text-[17px] font-bold text-dark dark:text-white leading-tight mb-0.5">
                  {item.company}
                </h4>
                <p class="z-10 relative text-xs lg:text-[13px] text-neutral-700 dark:text-darkmuted leading-snug">
                  {item.role}
                </p>
                
                <!-- Watermark Background Icon -->
                {item.icon && (
                  <Icon name={item.icon} class="absolute w-20 h-20 text-neutral-500/6 dark:text-white/4 pointer-events-none z-0 transform transition-all duration-500 group-hover:scale-110 right-2 -bottom-4 translate-x-2 translate-y-2" />
                )}
                
                <span class="absolute inset-0 w-full h-full rounded-2xl overflow-hidden pointer-events-none">
                  <span class="absolute top-0 -left-[100%] w-1/2 h-full bg-gradient-to-r from-transparent via-white/10 to-transparent skew-x-[-25deg] group-hover:animate-sheen"></span>
                </span>

              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
  
  <!-- Decorative Brushes -->
  <div class="left-10 top-[280px] absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/about/1.png" alt="" class="brush-float" />
  </div>
  <div class="-bottom-[50px] right-0 absolute hidden lg:block" data-animate="fade-in-right" data-animate-duration="1s">
    <img src="/img/brushes/about/2.png" alt="" class="brush-float-reverse" />
  </div>
</section>
