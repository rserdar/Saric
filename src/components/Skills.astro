---

<section class="py-[120px] md:py-[185px]" id="skills">
  <div class="container relative z-10">
    <div data-animate="fade-in-left" data-animate-duration="1s">
      <div class="mb-[23px]">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.skills.tag}</p>
        <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mt-1.5">{content.skills.title}</h3>
      </div>
      <p class="text-muted dark:text-darkmuted lg:max-w-[760px] leading-[30px]" data-animate="fade-in-up" data-animate-duration="1s">
        {labels.description}
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8">
        <ResumeColumn
          title={labels.workTitle}
          summary={labels.workSummary}
          borderClass="border-custom"
          pillClass="bg-custom/10 text-custom"
          items={workExperience}
          delayOffset={0}
          mobileOpen={true}
        />

        <div class="w-full max-w-[390px] mx-auto xl:pt-5">
          <details data-mobile-accordion class="group rounded-[28px] border border-black/5 bg-black/[0.04] shadow-[0_20px_60px_rgba(15,23,42,0.06)] backdrop-blur-sm dark:border-white/10 dark:bg-white/[0.04] xl:hidden">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5">
              <div class="min-w-0">
                <h3 class="border-l-4 border-[#0ea5e9] pl-3 font-secondary text-lg font-bold text-dark dark:text-white">
                  {labels.digitalTitle}
                </h3>
                <p class="mt-2 pl-3 text-sm leading-6 text-muted dark:text-darkmuted">
                  {labels.digitalSummary}
                </p>
              </div>
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-black/10 bg-white/50 text-dark transition-transform duration-300 group-open:rotate-45 dark:border-white/10 dark:bg-white/[0.04] dark:text-white">
                +
              </span>
            </summary>
            <div class="space-y-5 px-5 pb-5">
              {digitalSkillBars.map((skill) => (
                <div class="relative skill-bar-wrap">
                  <div class="mb-[9px] block">
                    <span class="text-base font-medium font-secondary inline-block capitalize">{skill.name}</span>
                    <span
                      class="absolute right-0 text-custom skill-pct"
                      data-value={skill.value}
                      style="opacity: 0;"
                    >{skill.value}%</span>
                  </div>
                  <div class="w-full bg-[#e7e5f1] rounded-full h-2">
                    <div
                      class="h-2 rounded-full skill-bar"
                      data-width={skill.value}
                      style={`width: 0%; background-color: ${skill.color}; transition: width 1.2s ease-in-out;`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </details>

          <div class="hidden xl:block">
            <div class="mb-8 border-l-4 border-[#0ea5e9] pl-4">
            <h3 class="font-secondary text-xl font-bold text-dark dark:text-white md:text-2xl">
              {labels.digitalTitle}
            </h3>
                </div>
            <div class="space-y-5 pl-4 pr-2" data-animate="fade-in-up" data-animate-duration="0.8s">
              {digitalSkillBars.map((skill) => (
                <div class="relative skill-bar-wrap">
                  <div class="mb-[9px] block">
                    <span class="text-base font-medium font-secondary inline-block capitalize">{skill.name}</span>
                    <span
                      class="absolute right-0 text-custom skill-pct"
                      data-value={skill.value}
                      style="opacity: 0;"
                    >{skill.value}%</span>
                  </div>
                  <div class="w-full bg-[#e7e5f1] rounded-full h-2">
                    <div
                      class="h-2 rounded-full skill-bar"
                      data-width={skill.value}
                      style={`width: 0%; background-color: ${skill.color}; transition: width 1.2s ease-in-out;`}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <ResumeColumn
        title={labels.certTitle}
        summary={labels.certSummary}
        borderClass="border-[#8067f0] dark:border-[#f0c45c]"
        pillClass="bg-[#8067f0]/10 text-[#5e45d1] dark:bg-[#f0c45c]/10 dark:text-[#f0c45c]"
        items={certificates}
        delayOffset={3}
      />
      <ResumeColumn
        title={labels.eduTitle}
        summary={labels.eduSummary}
        borderClass="border-[#1cbe59]"
        pillClass="bg-[#1cbe59]/10 text-[#13853c] dark:bg-[#1cbe59]/10 dark:text-[#1cbe59]"
        items={educationTimeline}
        delayOffset={6}
      />
    </div>
  </div>
</section>

<script>
  const bars = document.querySelectorAll<HTMLElement>('.skill-bar');
  const pcts = document.querySelectorAll<HTMLElement>('.skill-pct');
  let animated = false;
  const mobileAccordions = document.querySelectorAll<HTMLDetailsElement>('#skills [data-mobile-accordion]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !animated) {
        animated = true;
        bars.forEach((bar) => {
          const target = bar.getAttribute('data-width') ?? '0';
          bar.style.width = target + '%';
        });
        pcts.forEach((pct) => {
          pct.style.opacity = '1';
          pct.style.transition = 'opacity 0.5s ease 0.8s';
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const section = document.querySelector('.skill-bar-wrap')?.closest('section');
  if (section) observer.observe(section);

  mobileAccordions.forEach((accordion) => {
    accordion.addEventListener('toggle', () => {
      if (!accordion.open) return;
      mobileAccordions.forEach((other) => {
        if (other !== accordion) {
          other.open = false;
        }
      });
    });
  });
</script>
