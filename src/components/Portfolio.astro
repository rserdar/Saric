---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);
const categoryLabels = {
  en: {
    all: 'All',
    web: 'Web',
    automation: 'Automation',
    systems: 'Systems',
    pending: 'Visual pending',
  },
  tr: {
    all: 'Tümü',
    web: 'Web',
    automation: 'Otomasyon',
    systems: 'Sistemler',
    pending: 'Görsel bekleniyor',
  },
  bs: {
    all: 'Sve',
    web: 'Web',
    automation: 'Automatizacija',
    systems: 'Sistemi',
    pending: 'Vizual u pripremi',
  },
} as const;

const labels = categoryLabels[lang];
const categories = ['all', ...new Set(content.portfolioItems.map((item) => item.categoryKey))];
---

<section class="pt-[113px] md:pt-[185px] pb-[88px] md:pb-[165px] relative dizme_tm_section" id="portfolio">
  <div class="container relative z-10">
    <div class="grid grid-cols-1">
      <div class="text-center max-w-[760px] mx-auto">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.portfolio.tag}</p>
        <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mb-[23px] mt-1.5">{content.portfolio.title}</h3>
        <p class="text-muted dark:text-darkmuted text-lg leading-[30px]">{content.portfolio.description}</p>
      </div>
    </div>

    <div class="grid grid-cols-1">
      <div class="md:pt-[78px] pt-[53px] pb-[46px] md:pb-[56px]">
        <ul class="flex items-center gap-4 flex-wrap lg:gap-[26px] justify-center list-none" id="menu-filter">
          {categories.map((cat) => (
            <li class="shrink-0">
              <button
                type="button"
                class={`portfolio-filter-btn hover:text-custom text-base duration-300 ${cat === 'all' ? 'active text-custom' : ''}`}
                data-filter={cat}
              >
                {labels[cat as keyof typeof labels]}
              </button>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-[25px]" id="portfolio-grid">
      {content.portfolioItems.map((item, i) => (
        <article
          class="portfolio-card rounded-2xl overflow-hidden bg-white dark:bg-semilight shadow-[18px_0px_80px_rgba(15,20,35,0.08)]"
          data-category={item.categoryKey}
          data-animate="fade-in-up"
          data-animate-duration="1s"
          data-animate-delay={`${(i % 4) * 0.12}s`}
        >
          <div class="aspect-[4/3] relative bg-[linear-gradient(135deg,#1f2937_0%,#374151_45%,#4b5563_100%)] dark:bg-[linear-gradient(135deg,#16181d_0%,#23262d_45%,#2d3139_100%)] p-6 flex flex-col justify-between">
            <div class="flex items-start justify-between gap-3">
              <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-white/80">
                {item.category}
              </span>
              <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/50">
                {labels.pending}
              </span>
            </div>
            <div>
              <div class="text-4xl font-secondary font-medium leading-none text-white/10">0{i + 1}</div>
              <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/10 px-3 py-1 text-sm text-white/70">
                <span class="h-2 w-2 rounded-full bg-custom"></span>
                {item.category}
              </div>
            </div>
          </div>
          <div class="p-6">
            <h4 class="text-[22px] leading-[1.35] font-secondary font-medium">{item.title}</h4>
            <p class="mt-4 text-muted dark:text-darkmuted leading-[30px] text-[17px]">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
  <div class="left-[50px] top-[150px] absolute hidden lg:block" data-animate="fade-in-left" data-animate-duration="1.2s">
    <img src="/img/brushes/portfolio/1.png" alt="" class="brush-float" />
  </div>
  <div class="right-[10px] bottom-[51px] absolute hidden lg:block" data-animate="fade-in-right" data-animate-duration="1.2s" data-animate-delay="0.2s">
    <img src="/img/brushes/portfolio/2.png" alt="" class="brush-float-lr-reverse" />
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.portfolio-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.portfolio-card');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter ?? 'all';
        buttons.forEach((btn) => btn.classList.remove('active', 'text-custom'));
        button.classList.add('active', 'text-custom');

        cards.forEach((card) => {
          const category = card.dataset.category;
          const shouldShow = filter === 'all' || category === filter;
          card.classList.toggle('hidden', !shouldShow);
        });
      });
    });
  });
</script>
