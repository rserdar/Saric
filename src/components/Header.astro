---
import type { Locale } from '../lib/site';
import { getLocalePath, getLocalizedPath, getSiteContent, localeLabels, locales } from '../lib/site';
import { siteAssets } from '../data/siteAssets';

interface Props {
  lang?: Locale;
}
const { lang = 'tr' } = Astro.props as Props;
const content = await getSiteContent(lang);
const navItems = [
  { key: 'home', href: '#home', label: content.nav.home },
  { key: 'about', href: '#about', label: content.nav.about },
  { key: 'portfolio', href: '#portfolio', label: content.nav.portfolio },
  { key: 'service', href: '#service', label: content.nav.service },
  { key: 'blog', href: '#blog', label: content.nav.blog },
  { key: 'contact', href: '#contact', label: content.nav.contact },
];
const themeToggleLabel = lang === 'tr' ? 'Karanlık modu değiştir' : lang === 'bs' ? 'Promijeni tamni način rada' : 'Toggle dark mode';
const desktopInactiveClass = 'text-dark/75 dark:text-white/90';
const mobileInactiveClass = 'text-dark dark:text-white';
const desktopNavLinkClass = `inline-flex items-center px-1 py-2 font-secondary text-[15px] font-medium leading-none tracking-[-0.01em] transition-colors duration-300 hover:text-custom`;
const desktopLocaleWrapClass = 'flex items-center gap-1 rounded-full border-2 border-custom/80 bg-white/35 px-2 py-1.5 shadow-[0_10px_24px_rgba(15,23,42,0.06)] backdrop-blur-sm dark:bg-white/5 dark:shadow-none';
const desktopThemeButtonClass = 'relative z-10 flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border-2 border-custom text-dark/75 transition-[color,border-color,opacity] duration-300 before:absolute before:inset-x-[-5px] before:bottom-[-5px] before:z-[-10] before:h-0 before:bg-custom before:transition-[height] before:duration-300 hover:text-white hover:before:h-[calc(100%+10px)] dark:text-white/90';
const mobileThemeButtonClass = 'relative z-10 flex h-9 w-9 items-center justify-center overflow-hidden rounded-full border-2 border-custom text-dark transition-[color,border-color,opacity] duration-300 before:absolute before:inset-x-[-5px] before:bottom-[-5px] before:z-[-10] before:h-0 before:bg-custom before:transition-[height] before:duration-300 hover:text-white hover:before:h-[calc(100%+10px)] dark:text-white';
---

<div class="fixed top-0 w-full z-40">
  <nav
    id="main-nav"
    class="relative py-6 transition-[padding,background-color,box-shadow,backdrop-filter] duration-500 lg:py-8 xl:py-9 max-[768px]:bg-white/92 max-[768px]:py-[14px] max-[768px]:shadow-[0px_0px_10px_rgb(0,0,0,0.1)] max-[768px]:dark:bg-semidark"
  >
    <div class="container-wide">
      <div class="flex items-center justify-between">
          <div class="relative z-50 shrink-0">
            <a href={getLocalizedPath(lang, '#home')} class="inline-block">
              <img
                id="header-logo"
                src={siteAssets.logo.main.src}
                class="h-auto w-[124px] opacity-95 transition-all duration-500 hover:opacity-100 dark:opacity-80 dark:hover:opacity-100 dark:brightness-90 dark:hover:brightness-100 lg:w-[158px] xl:w-[170px]"
                alt="Serdar Yavuz"
              />
            </a>
          </div>
          <div class="md:hidden">
            <button class="mobile-menu-button -mr-2.5 block p-2.5 outline-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
          <div class="hidden md:flex md:items-center md:gap-6 lg:gap-8 xl:gap-10">
            <ul class="list-none flex items-center gap-5 lg:gap-7 xl:gap-8" data-nav-list>
              {navItems.map((item, index) => (
                <li data-nav-item>
                  <a
                    href={getLocalizedPath(lang, item.href)}
                    data-nav-link
                    class={`${desktopNavLinkClass} ${index === 0 ? '!text-custom' : desktopInactiveClass}`}
                    data-inactive-class={desktopInactiveClass}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
            <div class="flex items-center gap-3 lg:gap-4">
              <div class="relative">
                <div class={desktopLocaleWrapClass}>
                  {locales.map((locale) => (
                    <a
                      href={getLocalePath(locale)}
                      data-lang-link={locale}
                      class={`rounded-full px-2.5 py-1 text-[11px] font-semibold leading-none transition-colors duration-300 ${locale === lang ? 'bg-custom text-white' : 'text-muted dark:text-white/70 hover:bg-black/5 dark:hover:bg-white/5 hover:text-dark dark:hover:text-white'}`}
                    >
                      {localeLabels[locale]}
                    </a>
                  ))}
                </div>
              </div>
              <div class="shrink-0">
                <button id="theme-toggle" aria-label={themeToggleLabel} class={desktopThemeButtonClass}>
                  <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 dark:hidden" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
                  </svg>
                  <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 4a1 1 0 011-1V1a1 1 0 00-2 0v2a1 1 0 011 1zm0 16a1 1 0 011 1v2a1 1 0 00-2 0v-2a1 1 0 011-1zM4 12a1 1 0 01-1 1H1a1 1 0 010-2h2a1 1 0 011 1zm18 0a1 1 0 01-1 1h-2a1 1 0 010-2h2a1 1 0 011 1zM5.636 6.05a1 1 0 010-1.414L4.222 3.222a1 1 0 10-1.414 1.414L4.222 6.05a1 1 0 001.414 0zm12.728 11.314a1 1 0 010 1.414l-1.414 1.414a1 1 0 01-1.414-1.414l1.414-1.414a1 1 0 011.414 0zM5.636 17.95a1 1 0 01-1.414 0l-1.414-1.414a1 1 0 011.414-1.414l1.414 1.414a1 1 0 010 1.414zM18.364 6.05a1 1 0 001.414 0l1.414-1.414a1 1 0 00-1.414-1.414L18.364 4.636a1 1 0 000 1.414zM12 7a5 5 0 100 10A5 5 0 0012 7z"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
      </div>
      <div class="mobile-menu hidden md:hidden">
        <div class="pt-5">
          <ul class="list-none" data-mobile-nav-list>
            {navItems.map((item, index) => (
              <li data-nav-item>
                <a
                  href={getLocalizedPath(lang, item.href)}
                  data-nav-link
                  class={`inline-block p-2 font-secondary text-base font-medium leading-6 transition-colors duration-300 hover:text-custom ${index === 0 ? '!text-custom' : mobileInactiveClass}`}
                  data-inactive-class={mobileInactiveClass}
                >
                  {item.label}
                </a>
              </li>
            ))}
            <li class="mt-3">
              <div class="inline-flex items-center gap-1 rounded-full border-2 border-custom/80 bg-black/5 dark:bg-white/5 px-2 py-[7px]">
                {locales.map((locale) => (
                  <a
                    href={getLocalePath(locale)}
                    data-lang-link={locale}
                    class={`rounded-full px-3 py-1 text-xs font-semibold transition-colors duration-300 ${locale === lang ? 'bg-custom text-white' : 'text-muted dark:text-darkmuted hover:bg-black/5 dark:hover:bg-white/5 hover:text-dark dark:hover:text-white'}`}
                  >
                    {localeLabels[locale]}
                  </a>
                ))}
              </div>
            </li>
            <li class="mt-3">
              <button id="theme-toggle-mobile" aria-label={themeToggleLabel} class={mobileThemeButtonClass}>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 dark:hidden" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 4a1 1 0 011-1V1a1 1 0 00-2 0v2a1 1 0 011 1zm0 16a1 1 0 011 1v2a1 1 0 00-2 0v-2a1 1 0 011-1zM4 12a1 1 0 01-1 1H1a1 1 0 010-2h2a1 1 0 011 1zm18 0a1 1 0 01-1 1h-2a1 1 0 010-2h2a1 1 0 011 1zM5.636 6.05a1 1 0 010-1.414L4.222 3.222a1 1 0 10-1.414 1.414L4.222 6.05a1 1 0 001.414 0zm12.728 11.314a1 1 0 010 1.414l-1.414 1.414a1 1 0 01-1.414-1.414l1.414-1.414a1 1 0 011.414 0zM5.636 17.95a1 1 0 01-1.414 0l-1.414-1.414a1 1 0 011.414-1.414l1.414 1.414a1 1 0 010 1.414zM18.364 6.05a1 1 0 001.414 0l1.414-1.414a1 1 0 00-1.414-1.414L18.364 4.636a1 1 0 000 1.414zM12 7a5 5 0 100 10A5 5 0 0012 7z"/>
                </svg>
              </button>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>
</div>

<script>
  (() => {
    const stickyClasses = [
      'bg-white/75',
      'backdrop-blur-[14px]',
      'shadow-[0_12px_34px_rgba(0,0,0,0.08)]',
      'dark:bg-semidark/75',
      'dark:shadow-[0_12px_34px_rgba(0,0,0,0.24)]',
      '!py-4',
    ];
    const stickyLogoClasses = [
      '!w-[112px]',
      'lg:!w-[138px]',
      'xl:!w-[148px]',
    ];

    const triggerSpin = (btn: HTMLElement | null) => {
      if (!btn) return;
      const svgs = btn.querySelectorAll('svg');
      svgs.forEach((svg) => {
        if (svg.clientWidth > 0 || svg.clientHeight > 0) {
          svg.classList.remove('animate-theme-spin');
          void (svg as unknown as HTMLElement).offsetWidth;
          svg.classList.add('animate-theme-spin');

          svg.addEventListener('animationend', () => {
            svg.classList.remove('animate-theme-spin');
          }, { once: true });
        }
      });
    };

    const initHeader = () => {
      const nav = document.getElementById('main-nav');
      if (!(nav instanceof HTMLElement) || nav.dataset.headerBound === 'true') return;
      nav.dataset.headerBound = 'true';
      const logo = document.getElementById('header-logo');

      const mobileBtn = document.querySelector('.mobile-menu-button');
      const mobileMenu = document.querySelector('.mobile-menu');
      const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));

      const syncStickyState = () => {
        const isSticky = window.scrollY >= 100;
        stickyClasses.forEach((className) => {
          nav.classList.toggle(className, isSticky);
        });
        stickyLogoClasses.forEach((className) => {
          logo?.classList.toggle(className, isSticky);
        });
      };

      const syncActiveSection = () => {
        const sections = Array.from(document.querySelectorAll('section[id]'));
        const top = window.scrollY;

        const currentSection = sections.find((section) => {
          const el = section as HTMLElement;
          const offset = el.offsetTop - 150;
          const height = el.offsetHeight;
          return top >= offset && top < offset + height;
        });

        const currentId = currentSection?.getAttribute('id') ?? 'home';
        navLinks.forEach((link) => {
          link.classList.remove('!text-custom');
          const inactiveClass = link.getAttribute('data-inactive-class');
          if (inactiveClass) {
            inactiveClass.split(' ').forEach((className) => {
              if (className) link.classList.add(className);
            });
          }
        });

        navLinks.forEach((link) => {
          const href = link.getAttribute('href') || '';
          if (!href.endsWith(`#${currentId}`)) return;
          const inactiveClass = link.getAttribute('data-inactive-class');
          if (inactiveClass) {
            inactiveClass.split(' ').forEach((className) => {
              if (className) link.classList.remove(className);
            });
          }
          link.classList.add('!text-custom');
        });
      };

      syncStickyState();
      syncActiveSection();
      window.addEventListener('scroll', syncStickyState);
      window.addEventListener('scroll', syncActiveSection);
      window.addEventListener('resize', syncActiveSection);

      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }

      navLinks.forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
        });
      });

      const toggleTheme = (e: Event) => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        triggerSpin(e.currentTarget as HTMLElement);
      };

      document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

      document.querySelectorAll('[data-lang-link]').forEach((link) => {
        link.addEventListener('click', () => {
          const targetLang = link.getAttribute('data-lang-link');
          if (targetLang) {
            localStorage.setItem('lang-preference', targetLang);
          }
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeader, { once: true });
    } else {
      initHeader();
    }

    document.addEventListener('astro:page-load', initHeader);
  })();
</script>
