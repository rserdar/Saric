---
import { Icon } from 'astro-icon/components';

interface ResumeItem {
  year: string;
  title: string;
  subtitle: string;
  icon?: string;
  color: 'green' | 'yellow' | 'blue' | 'orange' | 'cyan' | 'rose';
}

interface Props {
  title: string;
  summary: string;
  borderClass: string;
  items: ResumeItem[];
  delayOffset?: number;
  mobileOpen?: boolean;
}

const { title, summary, borderClass, items, delayOffset = 0, mobileOpen = false } = Astro.props as Props;

const colorThemes = {
  green: {
    dot: 'bg-[#1cbe59] text-white',
    card: 'bg-[#edf3ec]/90 border-[#1cbe59]/20',
    badge: 'bg-[#1cbe59]/10 text-[#13853c] dark:text-[#1cbe59]',
  },
  yellow: {
    dot: 'bg-[#ffb324] text-white',
    card: 'bg-[#fdfaf2]/90 border-[#ffb324]/20',
    badge: 'bg-[#ffb324]/10 text-[#b27600] dark:text-[#ffb324]',
  },
  blue: {
    dot: 'bg-[#8067f0] text-white',
    card: 'bg-[#f5f3f7]/90 border-[#8067f0]/20',
    badge: 'bg-[#8067f0]/10 text-[#5e45d1] dark:text-[#a391fc]',
  },
  orange: {
    dot: 'bg-custom text-white',
    card: 'bg-[#fdf6f0]/90 border-[#f75023]/20',
    badge: 'bg-custom/10 text-[#d93c14] dark:text-custom',
  },
  cyan: {
    dot: 'bg-[#0ea5e9] text-white',
    card: 'bg-[#f0f7fa]/90 border-[#0ea5e9]/20',
    badge: 'bg-[#0ea5e9]/10 text-[#0369a1] dark:text-[#38bdf8]',
  },
  rose: {
    dot: 'bg-[#fb7185] text-white',
    card: 'bg-[#faf2f4]/90 border-[#fb7185]/20',
    badge: 'bg-[#fb7185]/10 text-[#be123c] dark:text-[#fda4af]',
  },
} as const;
---

<div class="w-full max-w-[390px] mx-auto">
  <details data-mobile-accordion class="group rounded-[28px] border border-black/5 bg-black/[0.04] shadow-[0_20px_60px_rgba(15,23,42,0.06)] backdrop-blur-sm dark:border-white/10 dark:bg-white/[0.04] lg:hidden" open={mobileOpen}>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5">
      <div class="min-w-0">
        <h3 class={`border-l-4 pl-3 font-secondary text-lg font-bold text-dark dark:text-white ${borderClass}`}>{title}</h3>
        <p class="mt-2 pl-3 text-sm leading-6 text-muted dark:text-darkmuted">{summary}</p>
      </div>
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-black/10 bg-white/50 text-dark transition-transform duration-300 group-open:rotate-45 dark:border-white/10 dark:bg-white/[0.04] dark:text-white">
        +
      </span>
    </summary>

    <div class="relative space-y-4 px-4 pb-4 pt-1">
      <div class="absolute bottom-6 left-[23px] top-3 w-px bg-black/10 dark:bg-white/10"></div>
      {items.map((item) => {
        const theme = colorThemes[item.color];
        return (
          <div class="relative pl-8">
            <div class={`absolute left-0 top-4 flex h-[18px] w-[18px] items-center justify-center rounded-full border-4 border-white shadow-md dark:border-semidark ${theme.dot}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class={`relative overflow-hidden rounded-2xl border px-4 py-4 shadow-[0_8px_24px_rgba(0,0,0,0.08)] transition-all duration-300 dark:border-white/[0.12] dark:bg-[rgba(55,58,74,0.70)] dark:shadow-[0_8px_24px_rgba(0,0,0,0.28)] ${theme.card}`}>
            <span class={`mb-2 inline-block rounded-full px-2.5 py-1 text-[11px] font-bold ${theme.badge}`}>
              {item.year}
            </span>
            <h4 class="pr-12 font-jost text-base font-bold leading-tight text-dark dark:text-white">{item.title}</h4>
            <p class="mt-1 pr-10 text-sm leading-snug text-neutral-700 dark:text-darkmuted">{item.subtitle}</p>
            {item.icon && <Icon name={item.icon} class="absolute bottom-3 right-3 h-14 w-14 text-neutral-700/8 dark:text-white/[0.08]" />}
            </div>
          </div>
        );
      })}
    </div>
  </details>

  <div class="relative hidden overflow-visible lg:block">
    <h3 class={`mb-8 border-l-4 pl-4 font-secondary text-xl font-bold text-dark dark:text-white md:text-2xl ${borderClass}`}>
      {title}
    </h3>

    <div class="absolute bottom-2 left-8 top-20 w-0.5 bg-neutral-200 dark:bg-white/10"></div>

    <div class="relative space-y-6 pl-14 pr-2">
      {items.map((item, index) => {
        const theme = colorThemes[item.color];
        return (
          <div class="group relative" data-animate="fade-in-up" data-animate-duration="0.8s" style={`animation-delay: ${(index + delayOffset) * 120}ms;`}>
            <div class="absolute -left-[35px] top-4 z-10 flex items-center justify-center">
              <span class={`flex h-[20px] w-[20px] items-center justify-center rounded-full border-4 border-white shadow-md transition-transform duration-300 hover:scale-115 dark:border-semidark ${theme.dot}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>

            <div class={`relative flex w-full flex-col items-start overflow-hidden rounded-2xl border px-5 py-3.5 text-left shadow-[0_4px_20px_rgba(0,0,0,0.03)] transition-all duration-300 hover:-translate-y-1 hover:border-custom/20 hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] dark:border-white/[0.12] dark:bg-[rgba(55,58,74,0.70)] dark:shadow-[0_4px_20px_rgba(0,0,0,0.28)] dark:hover:bg-[rgba(65,68,86,0.90)] dark:hover:shadow-[0_12px_32px_rgba(0,0,0,0.36)] ${theme.card}`}>
              <span class={`relative z-10 mb-1.5 inline-block rounded-full px-2.5 py-0.5 text-[11px] font-bold shadow-sm ${theme.badge}`}>
                {item.year}
              </span>
              <h4 class="relative z-10 mb-0.5 font-jost text-base font-bold leading-tight text-dark dark:text-white lg:text-[17px]">
                {item.title}
              </h4>
              <p class="relative z-10 text-xs leading-snug text-neutral-700 dark:text-darkmuted lg:text-[13px]">
                {item.subtitle}
              </p>

              {item.icon && (
                <Icon name={item.icon} class="pointer-events-none absolute -bottom-4 right-2 z-0 h-20 w-20 translate-x-2 translate-y-2 text-neutral-500/8 transition-all duration-500 group-hover:scale-110 dark:text-white/[0.08]" />
              )}

              <span class="pointer-events-none absolute inset-0 h-full w-full overflow-hidden rounded-2xl">
                <span class="absolute -left-[100%] top-0 h-full w-1/2 skew-x-[-25deg] bg-gradient-to-r from-transparent via-white/10 to-transparent group-hover:animate-sheen"></span>
              </span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>
