---
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';
import { Icon } from 'astro-icon/components';
import GoogleMap from './GoogleMap.astro';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const content = await getSiteContent(lang);
const contactInputClass = "h-[58px] w-full rounded-xl border border-[#d6dbe5] bg-white px-[30px] text-lg leading-7 text-dark outline-none transition-colors duration-300 placeholder:text-muted focus:outline-none dark:border-white/15 dark:bg-semidark dark:text-darkmuted dark:placeholder:text-darkmuted";
const primaryButtonClass = "relative z-10 inline-block overflow-hidden rounded-full border-2 border-custom px-[35px] py-[14px] font-secondary font-medium text-white transition-all duration-300 before:absolute before:inset-x-[-5px] before:bottom-[-5px] before:z-[-1] before:h-[112%] before:bg-custom before:transition-[height] before:duration-300 hover:text-black hover:before:h-0 md:px-12 dark:text-white";
---

<section class="relative pt-[123px] pb-[120px] md:pt-[190px] md:pb-[200px]" id="contact">
  <div class="container">
    <div class="grid grid-cols-1">
      <div class="text-center max-w-[720px] mx-auto">
        <p class="text-custom text-[20px] md:text-2xl font-medium font-secondary">{content.contact.tag}</p>
        <h3 class="text-[30px] sm:text-[38px] md:text-[48px] leading-[1.25] mb-[23px] mt-1.5">{content.contact.title}</h3>
        <p class="text-muted dark:text-darkmuted text-lg leading-[30px]">{content.contact.description}</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 mt-20 gap-[25px]">
      <div class="space-y-[15px]" data-animate="fade-in-left" data-animate-duration="1s">
        <div class="flex items-center gap-[25px]">
          <div class="shrink-0 h-[88px] w-[88px] rounded-full bg-[#fedfd7] flex items-center justify-center">
            <Icon name="fa6-solid:location-dot" class="w-6 h-6 text-custom" />
          </div>
          <div>
            <h5 class="md:text-[30px] text-[25px]">{content.contact.locationTitle}</h5>
            <p class="text-lg mt-1.5 text-muted dark:text-darkmuted leading-8">{content.contact.locationText}</p>
          </div>
        </div>
        <div class="flex items-center gap-[25px]">
          <div class="shrink-0 h-[88px] w-[88px] rounded-full bg-[#ddf5e6] flex items-center justify-center">
            <Icon name="fa6-solid:globe" class="w-6 h-6 text-[#1cbe59]" />
          </div>
          <div>
            <h5 class="md:text-[30px] text-[25px]">{content.contact.webTitle}</h5>
            <a href={`https://${content.globals.web}`} target="_blank" rel="noopener noreferrer" class="text-lg mt-1.5 text-muted dark:text-darkmuted leading-8 hover:text-custom transition-colors duration-300 inline-block">
              {content.globals.web}
            </a>
          </div>
        </div>
      </div>

      <div data-animate="fade-in-right" data-animate-duration="1s">
        <form class="rounded-2xl bg-white dark:bg-semilight p-6 md:p-8 shadow-[18px_0px_87px_rgba(10,15,17,0.07)]">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div>
              <label class="block">
                <input type="text" class={contactInputClass} placeholder={content.contact.fields.name} required />
              </label>
            </div>
            <div>
              <label class="block">
                <input type="email" class={contactInputClass} placeholder={content.contact.fields.email} required />
              </label>
            </div>
            <div class="md:col-span-2">
              <label class="block">
                <input type="text" class={contactInputClass} placeholder={content.contact.fields.subject} required />
              </label>
            </div>
            <div class="md:col-span-2">
              <label class="block">
                <textarea class={`${contactInputClass} h-auto pt-4`} rows="7" placeholder={content.contact.fields.message} required></textarea>
              </label>
            </div>
            <div class="md:col-span-2">
              <button type="submit" class={primaryButtonClass}>{content.contact.fields.submit}</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="top-[100px] absolute left-0 hidden lg:block" data-animate="fade-in-left" data-animate-duration="1s">
    <img src="/img/brushes/contact/1.png" alt="" class="brush-float-lr" />
  </div>
  <div class="absolute bottom-[100px] right-[150px] hidden lg:block" data-animate="fade-in-right" data-animate-duration="1s">
    <img src="/img/brushes/contact/2.png" alt="" class="brush-float-reverse" />
  </div>
</section>

<section class="relative pb-[60px] md:pb-[80px]">
  <div 
    class="w-full overflow-hidden border-t-[3px] border-b-[3px] border-l-0 border-r-0 border-transparent bg-white dark:bg-semidark [--inner-bg:#ffffff] dark:[--inner-bg:#2b2d33]"
    style="
      background-image: linear-gradient(to right, var(--inner-bg), var(--inner-bg)), 
                        repeating-linear-gradient(-45deg, #f75023 0, #f75023 4px, transparent 4px, transparent 8px, #1cbe59 8px, #1cbe59 12px, transparent 12px, transparent 16px);
      background-clip: padding-box, border-box;
      background-origin: padding-box, border-box;
    "
  >
    <GoogleMap 
      src={content.contactMapEmbed} 
      title="Location Map" 
    />
  </div>
</section>
