---
interface Props {
  href: string;
  className?: string;
  target?: string;
}

const { href, className = "", target = "_self" } = Astro.props;
---

<div class={`inline-block ${className}`}>
  <a 
    href={href} 
    target={target}
    class="no-underline text-white inline-block font-jost font-medium rounded-[50px] border-2 border-[var(--color-main-orange)] px-12 py-[14px] relative overflow-hidden group transition-all duration-300 bg-[var(--color-main-orange)]"
  >
    <span class="relative z-10 transition-colors duration-300 group-hover:text-heading">
      <slot />
    </span>
    {/* This white overlay slides in from the bottom on hover */}
    <div class="absolute inset-0 bg-white translate-y-full transition-transform duration-300 group-hover:translate-y-0 z-0"></div>
  </a>
</div>
