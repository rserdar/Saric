---
---

<div
  id="preloader"
  class="fixed inset-0 z-[9999] flex items-center justify-center bg-white/80 backdrop-blur-md transition-all duration-300 ease-out dark:bg-semidark/80"
  role="status"
  aria-label="Loading"
>
  <img
    src="/img/preloader.webp"
    alt=""
    width="240"
    height="180"
    loading="eager"
    decoding="async"
    class="h-[180px] w-60 object-contain mix-blend-multiply dark:mix-blend-normal"
  />
</div>

<script is:inline>
  (() => {
    const preloaderEl = document.getElementById('preloader');
    if (!preloaderEl) return;

    const startedAt = performance.now();
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const minimumVisibleMs = reduceMotion ? 0 : 550;
    let removed = false;

    const fadeOutAndRemove = () => {
      if (removed) return;
      removed = true;
      preloaderEl.classList.add('pointer-events-none', 'invisible', 'opacity-0');
      window.setTimeout(() => {
        preloaderEl.remove();
        document.body.classList.add('opened');
      }, 350);
    };

    const finishWhenReady = () => {
      const elapsed = performance.now() - startedAt;
      window.setTimeout(fadeOutAndRemove, Math.max(0, minimumVisibleMs - elapsed));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', finishWhenReady, { once: true });
    } else {
      finishWhenReady();
    }

    window.setTimeout(fadeOutAndRemove, reduceMotion ? 100 : 900);
  })();
</script>
