---
---

<style is:global>
  .brush-bloom {
    animation: brush-bloom 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-play-state: paused;
  }

  .brush-radial {
    animation: brush-radial 0.75s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-play-state: paused;
  }

  .brush-float {
    animation: brush-float 5s ease-in-out infinite;
  }

  .brush-float-reverse {
    animation: brush-float-reverse 5s ease-in-out infinite;
    animation-delay: -2.5s;
  }

  .brush-float-lr {
    animation: brush-float-lr 6s ease-in-out infinite;
  }

  .brush-float-lr-reverse {
    animation: brush-float-lr-reverse 6s ease-in-out infinite;
    animation-delay: -3s;
  }

  [data-animate] {
    opacity: 0;
  }

  [data-animate].is-visible {
    opacity: 1;
  }

  [data-animate="fade-in-up"].is-visible {
    animation: fade-in-up var(--anim-dur, 0.8s) ease both;
  }

  [data-animate="fade-in-left"].is-visible {
    animation: fade-in-left var(--anim-dur, 0.8s) ease both;
  }

  [data-animate="fade-in-right"].is-visible {
    animation: fade-in-right var(--anim-dur, 0.8s) ease both;
  }

  [data-animate="fade-in"].is-visible {
    animation: fade-in var(--anim-dur, 0.8s) ease both;
  }

  [data-animate="zoom-in"].is-visible {
    animation: zoom-in var(--anim-dur, 0.8s) ease both;
  }

  [data-animate="bounce-scale"].is-visible {
    animation: bounce-scale var(--anim-dur, 1s) linear both;
  }

  .animate-theme-spin {
    animation: theme-spin 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes brush-bloom {
    0% { transform: scale(0) rotate(-10deg); opacity: 0; }
    60% { transform: scale(1.14) rotate(3deg); opacity: 1; }
    80% { transform: scale(0.95) rotate(-1deg); }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  @keyframes brush-radial {
    0% { transform: scale(0); opacity: 0; }
    55% { transform: scale(1.18); opacity: 1; }
    78% { transform: scale(0.94); }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes brush-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  @keyframes brush-float-reverse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(14px); }
  }

  @keyframes brush-float-lr {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-12px); }
  }

  @keyframes brush-float-lr-reverse {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(12px); }
  }

  @keyframes bounce-scale {
    0%, 20%, 40%, 60%, 80%, 100% {
      animation-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);
    }

    0% {
      opacity: 0;
      transform: scale3d(0.3, 0.3, 0.3);
    }

    20% {
      transform: scale3d(1.1, 1.1, 1.1);
    }

    40% {
      transform: scale3d(0.9, 0.9, 0.9);
    }

    60% {
      opacity: 1;
      transform: scale3d(1.03, 1.03, 1.03);
    }

    80% {
      transform: scale3d(0.97, 0.97, 0.97);
    }

    100% {
      opacity: 1;
      transform: scale3d(1, 1, 1);
    }
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translate3d(0, 60px, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes fade-in-left {
    from { opacity: 0; transform: translate3d(-100%, 0, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes fade-in-right {
    from { opacity: 0; transform: translate3d(100%, 0, 0); }
    to { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes zoom-in {
    from { opacity: 0; transform: scale(0.75); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes theme-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<script is:inline>
  (() => {
    const initAnimations = () => {
      const animateElements = Array.from(document.querySelectorAll('[data-animate]'))
        .filter((element) => !element.hasAttribute('data-animate-bound'));
      if (!animateElements.length) return;

      const reveal = (element) => {
        const delay = element.getAttribute('data-animate-delay') || '0s';
        const duration = element.getAttribute('data-animate-duration') || '0.8s';
        element.style.setProperty('--anim-dur', duration);
        element.style.animationDelay = delay;
        element.classList.add('is-visible');
      };

      if (!('IntersectionObserver' in window)) {
        animateElements.forEach((element) => {
          element.setAttribute('data-animate-bound', 'true');
          reveal(element);
        });
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          reveal(entry.target);
          observer.unobserve(entry.target);
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -32px 0px',
      });

      animateElements.forEach((element) => {
        element.setAttribute('data-animate-bound', 'true');
        observer.observe(element);
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAnimations, { once: true });
    } else {
      initAnimations();
    }

    document.addEventListener('astro:page-load', initAnimations);
  })();
</script>
