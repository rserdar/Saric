---
import '../styles/global.css';

import Header from '../components/Header.astro';
import PreLoader from '../components/PreLoader.astro';
import Cursor from '../components/Cursor.astro';
import Progressbar from '../components/Progressbar.astro';
import CopyRight from '../components/CopyRight.astro';
import type { Locale } from '../lib/site';
import { getSiteContent } from '../lib/site';

interface Props {
	title?: string;
	lang?: Locale;
}

const { title = "Serdar Yavuz | Portföy", lang = 'tr' } = Astro.props as Props;
const content = await getSiteContent(lang);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={content.about.title} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Dark mode & Language Redirect: Render öncesi tema ve dil tercihlerini ayarlar -->
		<script is:inline>
			(function() {
				// 1. Tema Ayarı
				const saved = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (saved === 'dark' || (!saved && prefersDark)) {
					document.documentElement.classList.add('dark');
				}

				// 2. Dil Yönlendirme Mantığı
				const path = window.location.pathname;

				// Eğer zaten yerelleştirilmiş bir sayfadaysak tercihi kaydet ve yönlendirme yapma
				if (path.startsWith('/en/') || path === '/en') {
					localStorage.setItem('lang-preference', 'en');
					return;
				}
				if (path.startsWith('/bs/') || path === '/bs') {
					localStorage.setItem('lang-preference', 'bs');
					return;
				}

				// Yalnızca kök dizindeyken (/ veya /index.html) tarayıcı diline göre yönlendir
				if (path === '/' || path === '/index.html') {
					// Kullanıcı daha önce manuel seçim yaptıysa yönlendirme yapma
					if (localStorage.getItem('lang-preference')) return;

					// Kendi sitemizden bir linke tıklayarak geri geldiyse (navigasyon) yönlendirme yapma
					const referrer = document.referrer;
					if (referrer && referrer.includes(window.location.hostname)) {
						localStorage.setItem('lang-preference', 'tr');
						return;
					}

					// Tarayıcı dilini algıla
					const browserLang = (navigator.language || navigator.userLanguage || '').split('-')[0].toLowerCase();
					
					if (browserLang === 'en') {
						localStorage.setItem('lang-preference', 'en');
						window.location.href = '/en/';
					} else if (browserLang === 'bs' || browserLang === 'hr' || browserLang === 'sr') {
						localStorage.setItem('lang-preference', 'bs');
						window.location.href = '/bs/';
					} else if (browserLang === 'tr') {
						localStorage.setItem('lang-preference', 'tr');
					}
				}
			})();
		</script>

		<link
			href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700;1,800&display=swap"
			rel="stylesheet"
		/>

	</head>
	<body class="antialiased text-lg leading-[30px] font-primary text-dark dark:bg-semidark dark:text-white overflow-x-hidden">
		<PreLoader />
		
		<div class="dizme_tm_all_wrap" data-magic-cursor="show">
			<Header lang={lang} />
			
			<slot />
			
			<CopyRight lang={lang} />
			<Cursor />
			<Progressbar />
		</div>

		<script>
			import {
				wowJsAnimation,
				aTagClick,
				dataImage,
				scroll_,
				stickyNav
			} from '../utilits';

			wowJsAnimation();
			aTagClick();
			dataImage();
			scroll_();

			window.addEventListener("scroll", stickyNav);
		</script>
	</body>
</html>
