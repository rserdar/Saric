---
import '../styles/global.css';
import SharedMotion from '../components/SharedMotion.astro';
import Progressbar from '../components/Progressbar.astro';
import auroraBackground from '../assets/img/links/aurora.webp';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { 
  title = "Serdar Yavuz", 
  description = "Kişisel blog, sosyal medya ve tüm bağlantılarım.",
  lang = "tr"
} = Astro.props;
const glowStarClass = "absolute rounded-full bg-white opacity-20 [will-change:opacity,transform] [animation:var(--animate-star-pulse)] [animation-duration:var(--star-duration)] [animation-delay:var(--star-delay)] [filter:drop-shadow(0_0_3px_rgba(255,255,255,0.95))]";
const shootingStarClass = "absolute h-[3px] w-[140px] opacity-0 [will-change:transform,opacity] [background:linear-gradient(90deg,rgba(255,255,255,0.95)_0%,rgba(255,255,255,0.3)_50%,rgba(255,255,255,0)_100%)] [filter:drop-shadow(0_0_4px_rgba(255,255,255,0.6))] [transform:rotate(-35deg)_translate3d(0,0,0)_scaleX(0)] [animation:var(--animate-shoot)] [animation-duration:var(--shoot-duration)] [animation-delay:var(--shoot-delay)]";

// Parlayan Yıldızlar için rastgele parametre üreten fonksiyon
const generateStars = (count: number) => {
  const stars = [];
  for (let i = 0; i < count; i++) {
    stars.push({
      id: i,
      top: `${Math.random() * 85}%`, // Alt taraftaki ağaç silüetlerinin üst kısmında kalmaları için
      left: `${Math.random() * 100}%`,
      size: `${Math.random() * 2.5 + 1.2}px`, // 1.2px ile 3.7px arası (biraz daha belirgin)
      duration: `${Math.random() * 4 + 3}s`, // 3s ile 7s arası (yavaş ve tatlı parıldama)
      delay: `${Math.random() * 6}s`, // Rastgele başlama süreleri
    });
  }
  return stars;
};

const stars = generateStars(45); // Yıldız sayısını 45 yaptık, gökyüzü daha zengin ve belirgin dursun

// Kayan Yıldızlar (Shooting Stars) için parametreler
const generateShootingStars = (count: number) => {
  const shootingStars = [];
  for (let i = 0; i < count; i++) {
    shootingStars.push({
      id: i,
      top: `${Math.random() * 30 + 5}%`, // Üst tarafta (5% ile 35% arası)
      left: `${Math.random() * 60 + 10}%`, // Ekranın %10 ile %70'i arasından başlasın
      duration: '18s', // Toplam döngü süresi (18 saniyede bir tetiklenecek)
      delay: '4s', // Sayfa açıldıktan 4 saniye sonra ilk geçiş
    });
  }
  return shootingStars;
};

const shootingStars = generateShootingStars(1); // Sade durması için yalnızca 1 adet kayan yıldız döngüsü
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Dark Mode & Language Redirect: Render öncesi tema ve dil tercihlerini ayarlar -->
    <script is:inline>
      (function() {
        // 1. Tema Ayarı
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }

        // 2. Dil Yönlendirme Mantığı
        const path = window.location.pathname;

        // Eğer zaten yerelleştirilmiş bir sayfadaysak tercihi kaydet ve yönlendirme yapma
        if (path.startsWith('/en/links') || path === '/en/links' || path === '/en/links/') {
          localStorage.setItem('lang-preference', 'en');
          return;
        }
        if (path.startsWith('/bs/links') || path === '/bs/links' || path === '/bs/links/') {
          localStorage.setItem('lang-preference', 'bs');
          return;
        }

        // Yalnızca kök bağlantılar dizinindeyken (/links veya /links/index.html) tarayıcı diline göre yönlendir
        if (path === '/links' || path === '/links/' || path === '/links/index.html') {
          // Kullanıcı daha önce manuel seçim yaptıysa yönlendirme yapma
          if (localStorage.getItem('lang-preference')) return;

          // Kendi sitemizden bir linke tıklayarak geldiyse yönlendirme yapma
          const referrer = document.referrer;
          if (referrer && referrer.includes(window.location.hostname)) {
            localStorage.setItem('lang-preference', 'tr');
            return;
          }

          // Tarayıcı dilini algıla
          const browserLang = (navigator.language || navigator.userLanguage || '').split('-')[0].toLowerCase();
          
          if (browserLang === 'en') {
            localStorage.setItem('lang-preference', 'en');
            window.location.href = '/en/links';
          } else if (browserLang === 'bs' || browserLang === 'hr' || browserLang === 'sr') {
            localStorage.setItem('lang-preference', 'bs');
            window.location.href = '/bs/links';
          } else if (browserLang === 'tr') {
            localStorage.setItem('lang-preference', 'tr');
          }
        }
      })();
    </script>

  </head>
  <body class="relative isolate min-h-screen bg-[#07111f] text-white">
    <SharedMotion />
    
    <!-- Aurora Parallax Background -->
    <div class="fixed inset-0 z-0 h-full w-full select-none bg-cover bg-center bg-no-repeat transition-transform duration-1000 pointer-events-none" style={`background-image: url("${auroraBackground.src}");`}></div>
    
    <!-- Parlayan Yıldızlar Katmanı (GPU Hızlandırmalı) -->
    <div class="fixed inset-0 z-[1] h-full w-full overflow-hidden select-none pointer-events-none">
      {stars.map(star => (
        <div 
          class={glowStarClass}
          style={`
            top: ${star.top}; 
            left: ${star.left}; 
            width: ${star.size}; 
            height: ${star.size}; 
            --star-duration: ${star.duration}; 
            --star-delay: ${star.delay};
          `}
        />
      ))}
    </div>

    <!-- Kayan Yıldızlar Katmanı (Shooting Stars) -->
    <div class="fixed inset-0 z-[2] h-full w-full overflow-hidden select-none pointer-events-none">
      {shootingStars.map(s => (
        <div 
          class={shootingStarClass}
          style={`
            top: ${s.top}; 
            left: ${s.left}; 
            --shoot-duration: ${s.duration}; 
            --shoot-delay: ${s.delay};
          `}
        />
      ))}
    </div>

    <!-- Gradyan Karartma & Işık Katmanları -->
    <div class="fixed inset-0 z-[3] h-full w-full bg-gradient-to-b from-black/40 via-transparent to-black/60 pointer-events-none"></div>
    <div class="fixed inset-0 z-[4] h-full w-full bg-black/10 transition-colors duration-500 pointer-events-none dark:bg-black/30"></div>

    <main class="relative z-10 min-h-screen w-full">
      <slot />
    </main>

    <Progressbar variant="minimal" revealOffset={200} />

  </body>
</html>
